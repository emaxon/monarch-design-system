---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Dashboard Template" description="The full dashboard layout — sidebar, top bar, KPI cards, charts, and activity feed composed together.">

  <section class="mb-12">
    <p class="text-[var(--monarch-text-secondary)] mb-6">This template demonstrates how Atoms, Molecules, and Organisms compose into a complete dashboard view. This is a direct representation of the Monarch GTM OS dashboard.</p>

    <ComponentPreview title="Dashboard Layout (Scaled Preview)" background="elevated">
      <div class="rounded-xl bg-[var(--monarch-bg-base)] border border-[var(--monarch-border-subtle)] overflow-hidden" style="font-size: 10px;">
        <div class="flex">
          <!-- Mini Sidebar -->
          <div class="w-40 shrink-0 bg-[var(--monarch-bg-chrome)] border-r border-[var(--monarch-border-subtle)] p-2">
            <div class="flex items-center gap-1.5 px-2 py-2 mb-2">
              <div class="shrink-0 flex items-center justify-center" style="width: 18px; height: 18px; border-radius: 4px; background: linear-gradient(135deg, #7C55F5 0%, #AB76E2 100%);">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F7F5F3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" /><path d="M5 21h14" /></svg>
              </div>
              <svg style="height: 9px; width: auto;" viewBox="0 0 171 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Monarch" class="text-[var(--monarch-text-primary)]"><path d="M0.716916 0.342857H5.93363L13.0875 20.5143L20.2414 0.342857H25.3056V0.895238C24.4921 1.2127 24.1158 2.85079 24.1769 5.80952L24.6497 22.1905C24.7311 25.1619 25.1887 26.7873 26.0225 27.0667V27.6571H20.1499V27.0667C20.9838 26.7746 21.36 25.1492 21.2787 22.1905L20.7753 4.68571L13.5909 25.8286L11.4707 26.019L4.22523 4.68571L3.75237 21.6952C3.66085 24.9841 4.02693 26.7746 4.85062 27.0667V27.6571H0V27.0667C0.823691 26.7746 1.2813 24.9841 1.37282 21.6952L1.81517 5.80952C1.89652 2.86349 1.53044 1.2254 0.716916 0.895238V0.342857Z" fill="currentColor"/><path d="M30.7725 14C30.7725 9.73333 31.6724 6.33651 33.4724 3.80952C35.2723 1.26984 37.6722 0 40.672 0C43.6719 0 46.0667 1.26984 47.8564 3.80952C49.6462 6.33651 50.5411 9.73333 50.5411 14C50.5411 18.254 49.6462 21.6508 47.8564 24.1905C46.0667 26.7302 43.6719 28 40.672 28C37.6722 28 35.2723 26.7302 33.4724 24.1905C31.6724 21.6381 30.7725 18.2413 30.7725 14ZM36.0807 5.52381C34.952 7.61905 34.3876 10.4444 34.3876 14C34.3876 17.5556 34.952 20.3873 36.0807 22.4952C37.2196 24.5905 38.7501 25.6381 40.672 25.6381C42.5838 25.6381 44.1041 24.5905 45.2328 22.4952C46.3616 20.3873 46.926 17.5556 46.926 14C46.926 10.4444 46.3616 7.61905 45.2328 5.52381C44.1041 3.42857 42.5838 2.38095 40.672 2.38095C38.7501 2.38095 37.2196 3.42857 36.0807 5.52381Z" fill="currentColor"/><path d="M55.7639 0.895238V0.342857H60.3857L71.7801 20.019V6.32381C71.7801 3.02222 71.3682 1.2127 70.5446 0.895238V0.342857H75.4409V0.895238C74.6071 1.2254 74.1901 3.03492 74.1901 6.32381V27.7333H72.1309L59.4095 5.84762V21.6952C59.4095 24.9841 59.8264 26.7746 60.6603 27.0667V27.6571H55.7639V27.0667C56.5977 26.7746 57.0147 24.9841 57.0147 21.6952V5.80952C57.0147 2.86349 56.5977 1.2254 55.7639 0.895238Z" fill="currentColor"/><path d="M84.4771 27.6571H79.2604V27.0667C80.1858 26.6857 81.1417 24.9841 82.1281 21.9619L89.282 0.419048L91.6615 0.190476L98.9985 22.1905C99.9646 25.1492 100.915 26.7746 101.851 27.0667V27.6571H95.3834V27.0667C96.2986 26.7746 96.4003 25.5175 95.6885 23.2952L94.5292 19.7333H85.3161L84.2178 23.0476C83.4755 25.3587 83.5619 26.6984 84.4771 27.0667V27.6571ZM89.9074 5.42857L86.033 17.3143H93.8123L89.9074 5.42857Z" fill="currentColor"/><path d="M110.521 15.8857V22.1905C110.521 25.1492 110.938 26.7746 111.772 27.0667V27.6571H105.808V27.0667C106.642 26.7746 107.058 25.1492 107.058 22.1905V5.80952C107.058 2.86349 106.642 1.2254 105.808 0.895238V0.342857H114.578C116.928 0.342857 118.804 1.04762 120.207 2.45714C121.621 3.86667 122.327 5.75238 122.327 8.11429C122.327 9.81587 121.956 11.2825 121.214 12.5143C120.471 13.746 119.429 14.6476 118.087 15.219C119.073 15.9302 119.749 16.8254 120.115 17.9048L121.549 22.1905C122.526 25.1492 123.431 26.7746 124.264 27.0667V27.6571H119.856L119.46 27.1429L116.714 18.4571C116.46 17.6571 116.063 17.0286 115.524 16.5714C114.985 16.1143 114.38 15.8857 113.709 15.8857H110.521ZM114.578 2.7619H110.521V13.4667H114.578C115.839 13.4667 116.841 12.9841 117.583 12.019C118.336 11.054 118.712 9.75238 118.712 8.11429C118.712 6.48889 118.336 5.19365 117.583 4.22857C116.841 3.25079 115.839 2.7619 114.578 2.7619Z" fill="currentColor"/><path d="M138.365 0C140.999 0 143.256 0.768254 145.137 2.30476L144.634 6.51429C142.407 3.80952 140.221 2.45714 138.075 2.45714C136.031 2.45714 134.44 3.38413 133.301 5.23809C132.172 7.07936 131.608 9.66349 131.608 12.9905C131.608 16.7873 132.289 19.7397 133.651 21.8476C135.014 23.9556 136.906 25.0095 139.326 25.0095C140.383 25.0095 141.39 24.819 142.346 24.4381C143.302 24.0444 144.131 23.5048 144.832 22.819L145.259 25.0476C143.236 27.0159 140.821 28 138.014 28C134.872 28 132.421 26.781 130.662 24.3429C128.903 21.9048 128.023 18.4952 128.023 14.1143C128.023 9.64444 128.933 6.17778 130.753 3.71429C132.584 1.2381 135.121 0 138.365 0Z" fill="currentColor"/><path d="M150.33 0.895238V0.342857H156.294V0.895238C155.46 1.2254 155.043 2.86349 155.043 5.80952V12.5905H165.69V5.80952C165.69 2.85079 165.278 1.2127 164.454 0.895238V0.342857H170.419V0.895238C169.585 1.2254 169.168 2.86349 169.168 5.80952V22.1905C169.168 25.1492 169.585 26.7746 170.419 27.0667V27.6571H164.454V27.0667C165.278 26.7873 165.69 25.1619 165.69 22.1905V15.0095H155.043V22.1905C155.043 25.1492 155.46 26.7746 156.294 27.0667V27.6571H150.33V27.0667C151.164 26.7746 151.58 25.1492 151.58 22.1905V5.80952C151.58 2.86349 151.164 1.2254 150.33 0.895238Z" fill="currentColor"/></svg>
            </div>
            <p class="px-2 py-0.5 text-[8px] font-semibold text-[var(--monarch-text-muted)] uppercase tracking-widest">Intelligence</p>
            <div class="space-y-0.5">
              <a class="flex items-center gap-1.5 px-2 py-1 rounded bg-[rgba(124,85,245,0.1)] text-[var(--monarch-brand-violet)] text-[10px] font-medium">Dashboard</a>
              <a class="flex items-center gap-1.5 px-2 py-1 rounded text-[var(--monarch-text-muted)] text-[10px]">Morning Brief</a>
              <a class="flex items-center gap-1.5 px-2 py-1 rounded text-[var(--monarch-text-muted)] text-[10px]">Signal Graph</a>
            </div>
            <p class="px-2 py-0.5 mt-2 text-[8px] font-semibold text-[var(--monarch-text-muted)] uppercase tracking-widest">Revenue</p>
            <div class="space-y-0.5">
              <a class="flex items-center gap-1.5 px-2 py-1 rounded text-[var(--monarch-text-muted)] text-[10px]">Deal Board</a>
              <a class="flex items-center gap-1.5 px-2 py-1 rounded text-[var(--monarch-text-muted)] text-[10px]">Analytics</a>
            </div>
          </div>

          <!-- Main Content -->
          <div class="flex-1 min-w-0">
            <!-- Top Bar -->
            <div class="flex items-center justify-between px-3 py-2 border-b border-[var(--monarch-border-subtle)] bg-[var(--monarch-bg-chrome)]">
              <div class="flex items-center gap-1 text-[9px] text-[var(--monarch-text-muted)]">
                <span>Monarch</span><span>/</span><span class="text-[var(--monarch-text-secondary)]">Dashboard</span>
              </div>
              <div class="flex items-center gap-1.5">
                <div class="px-2 py-0.5 rounded bg-[var(--monarch-bg-elevated)] border border-[var(--monarch-border-subtle)] text-[8px] text-[var(--monarch-text-muted)]">⌘K Search...</div>
                <div class="w-5 h-5 rounded-full flex items-center justify-center text-[7px] font-bold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
              </div>
            </div>

            <div class="p-3 space-y-3">
              <!-- Greeting -->
              <div>
                <h2 class="text-sm font-bold">Good evening, Joe.</h2>
                <p class="text-[9px] text-[var(--monarch-text-muted)]">Here's your GTM overview for Friday, March 27.</p>
              </div>

              <!-- Stat Cards -->
              <div class="grid grid-cols-5 gap-2">
                <div class="p-2 rounded-lg bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)]">
                  <div class="text-base font-bold">433</div>
                  <div class="text-[8px] text-[var(--monarch-text-muted)] uppercase">Accounts</div>
                </div>
                <div class="p-2 rounded-lg bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)]">
                  <div class="text-base font-bold">$144.8M</div>
                  <div class="text-[8px] text-[var(--monarch-text-muted)] uppercase">Pipeline</div>
                </div>
                <div class="p-2 rounded-lg bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)]">
                  <div class="text-base font-bold">81</div>
                  <div class="text-[8px] text-[var(--monarch-text-muted)] uppercase">Avg Health</div>
                </div>
                <div class="p-2 rounded-lg bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)]">
                  <div class="text-base font-bold">20</div>
                  <div class="text-[8px] text-[var(--monarch-text-muted)] uppercase">Agents</div>
                </div>
                <div class="p-2 rounded-lg bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)]">
                  <div class="text-base font-bold">$3.01M</div>
                  <div class="text-[8px] text-[var(--monarch-text-muted)] uppercase">Tax Saved</div>
                </div>
              </div>

              <!-- Content Grid -->
              <div class="grid grid-cols-2 gap-2">
                <!-- Chart placeholder -->
                <div class="p-2 rounded-lg bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)]">
                  <p class="text-[9px] font-semibold mb-2">Pipeline by Stage</p>
                  <div class="space-y-1">
                    <div class="flex items-center gap-1"><span class="text-[7px] w-12 text-[var(--monarch-text-muted)]">Prospect</span><div class="h-2 rounded bg-[var(--monarch-brand-violet)]" style="width: 60%;"></div></div>
                    <div class="flex items-center gap-1"><span class="text-[7px] w-12 text-[var(--monarch-text-muted)]">Qualify</span><div class="h-2 rounded bg-[#AB76E2]" style="width: 45%;"></div></div>
                    <div class="flex items-center gap-1"><span class="text-[7px] w-12 text-[var(--monarch-text-muted)]">Proposal</span><div class="h-2 rounded bg-[#E0B2B3]" style="width: 30%;"></div></div>
                    <div class="flex items-center gap-1"><span class="text-[7px] w-12 text-[var(--monarch-text-muted)]">Negotiate</span><div class="h-2 rounded bg-[#3B82F6]" style="width: 20%;"></div></div>
                  </div>
                </div>
                <!-- Activity -->
                <div class="p-2 rounded-lg bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)]">
                  <p class="text-[9px] font-semibold mb-2">Agent Activity</p>
                  <div class="space-y-1.5">
                    <div class="text-[8px]"><span class="text-[var(--monarch-brand-violet)] font-semibold">Intelligence</span> <span class="text-[var(--monarch-text-muted)]">· 2m ago</span><br/><span class="text-[var(--monarch-text-secondary)]">11 accounts detected</span></div>
                    <div class="text-[8px]"><span class="text-[#3B82F6] font-semibold">Engagement</span> <span class="text-[var(--monarch-text-muted)]">· 5m ago</span><br/><span class="text-[var(--monarch-text-secondary)]">47 emails sent</span></div>
                    <div class="text-[8px]"><span class="text-[#EF4444] font-semibold">Revenue</span> <span class="text-[var(--monarch-text-muted)]">· 8m ago</span><br/><span class="text-[var(--monarch-text-secondary)]">Deal risk alert</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Composition</h2>
    <p class="text-[var(--monarch-text-secondary)] mb-4">This template combines:</p>
    <div class="space-y-2 text-[var(--monarch-text-secondary)]">
      <p>• <strong>Organism: Sidebar</strong> — grouped navigation with section headers</p>
      <p>• <strong>Molecule: Search Bar</strong> — ⌘K command palette trigger in the top bar</p>
      <p>• <strong>Atom: Avatar</strong> — user identity in the top bar</p>
      <p>• <strong>Molecule: Stat Cards</strong> — KPI overview row (5 cards)</p>
      <p>• <strong>Organism: Agent Feed</strong> — activity stream in the right column</p>
      <p>• <strong>Custom: Charts</strong> — pipeline visualization (CSS bar charts)</p>
      <p>• <strong>Molecule: Health Indicators</strong> — in the at-risk deals section</p>
    </div>
  </section>
</DocsLayout>
