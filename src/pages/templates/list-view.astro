---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="List View Template" description="The accounts/contacts list view — sidebar, filters, and data table composed together.">

  <section class="mb-12">
    <p class="text-[var(--monarch-text-secondary)] mb-6">This template shows how the sidebar, filter tabs, and data table compose into a full list view — the workhorse layout for managing accounts, contacts, and deals.</p>

    <ComponentPreview title="List View Layout (Scaled Preview)">
      <div class="rounded-xl bg-[var(--monarch-bg-base)] border border-[var(--monarch-border-subtle)] overflow-hidden" style="font-size: 10px;">
        <div class="flex">
          <!-- Mini Sidebar -->
          <div class="w-40 shrink-0 bg-[var(--monarch-bg-surface)] border-r border-[var(--monarch-border-subtle)] p-2">
            <div class="flex items-center gap-1.5 px-2 py-2 mb-2">
              <div class="shrink-0 flex items-center justify-center" style="width: 18px; height: 18px; border-radius: 4px; background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" /><path d="M5 21h14" /></svg>
              </div>
              <span class="font-semibold text-xs">Monarch</span>
            </div>
            <p class="px-2 py-0.5 text-[8px] font-semibold text-[var(--monarch-text-muted)] uppercase tracking-widest">Data Engine</p>
            <a class="flex items-center gap-1.5 px-2 py-1 rounded bg-[rgba(99,102,241,0.1)] text-[var(--monarch-brand-purple)] text-[10px] font-medium">Accounts</a>
          </div>

          <!-- Main Content -->
          <div class="flex-1 min-w-0">
            <!-- Top Bar -->
            <div class="flex items-center justify-between px-3 py-2 border-b border-[var(--monarch-border-subtle)] bg-[var(--monarch-bg-surface)]">
              <div class="flex items-center gap-1 text-[9px] text-[var(--monarch-text-muted)]">
                <span>Monarch</span><span>/</span><span class="text-[var(--monarch-text-secondary)]">Accounts</span>
              </div>
            </div>

            <div class="p-3">
              <!-- Page Header -->
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <h1 class="text-sm font-bold">Accounts</h1>
                  <span class="px-1 py-0.5 rounded-full text-[8px] font-medium bg-[var(--monarch-bg-elevated)] text-[var(--monarch-text-muted)]">433</span>
                </div>
                <button class="px-2 py-1 rounded text-[9px] font-semibold text-white" style="background: var(--monarch-brand-gradient);">+ Add Account</button>
              </div>

              <!-- Filters -->
              <div class="flex items-center gap-1.5 mb-3">
                <div class="flex rounded border border-[var(--monarch-border-subtle)] overflow-hidden">
                  <button class="px-2 py-0.5 text-[8px] font-medium bg-[var(--monarch-bg-elevated)] text-[var(--monarch-text-primary)]">All</button>
                  <button class="px-2 py-0.5 text-[8px] font-medium text-[var(--monarch-text-muted)]">Active</button>
                  <button class="px-2 py-0.5 text-[8px] font-medium text-[var(--monarch-text-muted)]">At Risk</button>
                  <button class="px-2 py-0.5 text-[8px] font-medium text-[var(--monarch-text-muted)]">Critical</button>
                </div>
                <div class="flex-1"></div>
                <div class="px-2 py-0.5 rounded bg-[var(--monarch-bg-elevated)] border border-[var(--monarch-border-subtle)] text-[8px] text-[var(--monarch-text-muted)]">🔍 Search...</div>
              </div>

              <!-- Table -->
              <div class="rounded-lg bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)] overflow-hidden">
                <table class="w-full">
                  <thead>
                    <tr class="border-b border-[var(--monarch-border-subtle)]">
                      <th class="px-2 py-1.5 text-left text-[8px] font-medium text-[var(--monarch-text-muted)] uppercase">Account</th>
                      <th class="px-2 py-1.5 text-left text-[8px] font-medium text-[var(--monarch-text-muted)] uppercase">Segment</th>
                      <th class="px-2 py-1.5 text-left text-[8px] font-medium text-[var(--monarch-text-muted)] uppercase">Health</th>
                      <th class="px-2 py-1.5 text-left text-[8px] font-medium text-[var(--monarch-text-muted)] uppercase">Pipeline</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="border-b border-[var(--monarch-border-subtle)]">
                      <td class="px-2 py-1.5 text-[9px] font-medium">The Kitchen Source</td>
                      <td class="px-2 py-1.5"><span class="px-1 py-0.5 rounded text-[7px] font-semibold bg-[rgba(59,130,246,0.15)] text-[#60A5FA]">Commercial</span></td>
                      <td class="px-2 py-1.5 text-[9px] font-semibold text-[#22C55E]">92</td>
                      <td class="px-2 py-1.5 text-[9px]">$2.4M</td>
                    </tr>
                    <tr class="border-b border-[var(--monarch-border-subtle)]">
                      <td class="px-2 py-1.5 text-[9px] font-medium">AK Design Group</td>
                      <td class="px-2 py-1.5"><span class="px-1 py-0.5 rounded text-[7px] font-semibold bg-[rgba(99,102,241,0.15)] text-[#818cf8]">Designer</span></td>
                      <td class="px-2 py-1.5 text-[9px] font-semibold text-[#F59E0B]">58</td>
                      <td class="px-2 py-1.5 text-[9px]">$285K</td>
                    </tr>
                    <tr>
                      <td class="px-2 py-1.5 text-[9px] font-medium">Baltix Construction</td>
                      <td class="px-2 py-1.5"><span class="px-1 py-0.5 rounded text-[7px] font-semibold bg-[rgba(34,197,94,0.15)] text-[#22C55E]">Fabricator</span></td>
                      <td class="px-2 py-1.5 text-[9px] font-semibold text-[#EF4444]">25</td>
                      <td class="px-2 py-1.5 text-[9px]">$154K</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Composition</h2>
    <div class="space-y-2 text-[var(--monarch-text-secondary)]">
      <p>• <strong>Organism: Sidebar</strong> — with "Accounts" active under Data Engine</p>
      <p>• <strong>Atom: Buttons</strong> — primary "Add Account" CTA, filter tab group</p>
      <p>• <strong>Molecule: Search Bar</strong> — inline search within the list view</p>
      <p>• <strong>Organism: Data Table</strong> — sortable columns, health scores, segment badges</p>
      <p>• <strong>Atom: Badges</strong> — color-coded segments (Commercial, Designer, Fabricator)</p>
      <p>• <strong>Molecule: Health Indicators</strong> — inline health scores with color coding</p>
    </div>
  </section>
</DocsLayout>
