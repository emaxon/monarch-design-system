---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Data Table" description="Sortable, filterable tables for accounts, deals, and contacts — the workhorse of B2B SaaS.">

  <section class="mb-12">
    <ComponentPreview title="Accounts Table" code='<div class="monarch-card">
  <div class="monarch-table-header">
    <div class="monarch-table-header__title">
      Accounts <span class="monarch-table-header__count">433</span>
    </div>
    <div class="monarch-filter-tabs">
      <button class="monarch-filter-tab monarch-filter-tab--active">All</button>
      <button class="monarch-filter-tab">Active</button>
    </div>
  </div>
  <table class="monarch-table">
    <thead><tr><th>Account</th><th>Segment</th><th>Health</th><th>Pipeline</th><th>Status</th></tr></thead>
    <tbody><tr><td>...</td></tr></tbody>
  </table>
</div>'>
      <div class="monarch-card monarch-card--no-hover">
        <div class="monarch-table-header">
          <div class="monarch-table-header__title">Accounts <span class="monarch-table-header__count">433</span></div>
          <div class="monarch-filter-tabs">
            <button class="monarch-filter-tab monarch-filter-tab--active">All</button>
            <button class="monarch-filter-tab">Active</button>
            <button class="monarch-filter-tab">At Risk</button>
          </div>
        </div>
        <div style="overflow-x: auto;">
          <table class="monarch-table">
            <thead>
              <tr>
                <th><span class="monarch-table__sortable">Account <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12" /></svg></span></th>
                <th>Segment</th>
                <th>Health</th>
                <th>Pipeline</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="monarch-avatar monarch-avatar-sm" style="border-radius: 8px; background: rgba(59,130,246,0.12); color: #3B82F6; font-size: 12px;">TK</div>
                    <div><div style="font-weight: 500;">The Kitchen Source</div><div style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">Dallas, TX</div></div>
                  </div>
                </td>
                <td><span class="monarch-badge monarch-badge-info">Commercial</span></td>
                <td>
                  <div class="monarch-health-ring monarch-health-ring-sm">
                    <svg class="monarch-health-ring__svg" viewBox="0 0 36 36"><path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" /><path class="monarch-health-ring__fill monarch-health-ring__fill--healthy" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="92, 100" /></svg>
                    <span class="monarch-health-ring__value" style="color: #22C55E;">92</span>
                  </div>
                </td>
                <td style="font-weight: 500;">$2,450,000</td>
                <td><span class="monarch-badge monarch-badge-success"><span class="monarch-badge__dot"></span> Active</span></td>
              </tr>
              <tr>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="monarch-avatar monarch-avatar-sm" style="border-radius: 8px; background: rgba(245,158,11,0.12); color: #F59E0B; font-size: 12px;">AK</div>
                    <div><div style="font-weight: 500;">AK Design Group</div><div style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">Chicago, IL</div></div>
                  </div>
                </td>
                <td><span class="monarch-badge monarch-badge-purple">Designer</span></td>
                <td>
                  <div class="monarch-health-ring monarch-health-ring-sm">
                    <svg class="monarch-health-ring__svg" viewBox="0 0 36 36"><path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" /><path class="monarch-health-ring__fill monarch-health-ring__fill--warning" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="58, 100" /></svg>
                    <span class="monarch-health-ring__value" style="color: #F59E0B;">58</span>
                  </div>
                </td>
                <td style="font-weight: 500;">$285,852</td>
                <td><span class="monarch-badge monarch-badge-warning"><span class="monarch-badge__dot"></span> At Risk</span></td>
              </tr>
              <tr>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="monarch-avatar monarch-avatar-sm" style="border-radius: 8px; background: rgba(239,68,68,0.12); color: #EF4444; font-size: 12px;">BC</div>
                    <div><div style="font-weight: 500;">Baltix Construction</div><div style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">Minneapolis, MN</div></div>
                  </div>
                </td>
                <td><span class="monarch-badge monarch-badge-success">Fabricator</span></td>
                <td>
                  <div class="monarch-health-ring monarch-health-ring-sm">
                    <svg class="monarch-health-ring__svg" viewBox="0 0 36 36"><path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" /><path class="monarch-health-ring__fill monarch-health-ring__fill--critical" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="25, 100" /></svg>
                    <span class="monarch-health-ring__value" style="color: #EF4444;">25</span>
                  </div>
                </td>
                <td style="font-weight: 500;">$154,527</td>
                <td><span class="monarch-badge monarch-badge-danger"><span class="monarch-badge__dot"></span> Critical</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </ComponentPreview>
  </section>
</DocsLayout>
