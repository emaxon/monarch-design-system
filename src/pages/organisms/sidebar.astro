---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Sidebar" description="The primary navigation structure — grouped sections, collapsible areas, and user profile.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Full Sidebar</h2>
    <p class="text-[var(--monarch-text-secondary)] mb-6">Direct reproduction of the Monarch prototype sidebar. Sections are grouped by product area with uppercase labels.</p>

    <ComponentPreview title="Application Sidebar">
      <div class="w-60 bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)] rounded-xl overflow-hidden">
        <!-- Logo -->
        <div class="flex items-center gap-2.5 px-5 py-4 border-b border-[var(--monarch-border-subtle)]">
          <span class="text-lg">👑</span>
          <span class="text-base font-semibold">Monarch</span>
        </div>

        <div class="py-3 px-3 space-y-4 max-h-96 overflow-y-auto">
          <!-- Intelligence -->
          <div>
            <p class="px-3 py-1 text-[10px] font-semibold text-[var(--monarch-text-muted)] uppercase tracking-[0.1em]">Intelligence</p>
            <div class="space-y-0.5">
              <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg bg-[rgba(124,58,237,0.1)] text-[var(--monarch-brand-purple)] border-l-2 border-[var(--monarch-brand-purple)] font-medium text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                Dashboard
              </a>
              <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                Morning Brief
              </a>
              <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                Signal Graph
              </a>
            </div>
          </div>

          <!-- Data Engine -->
          <div>
            <p class="px-3 py-1 text-[10px] font-semibold text-[var(--monarch-text-muted)] uppercase tracking-[0.1em]">Data Engine</p>
            <div class="space-y-0.5">
              <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                Accounts
              </a>
            </div>
          </div>

          <!-- Revenue -->
          <div>
            <p class="px-3 py-1 text-[10px] font-semibold text-[var(--monarch-text-muted)] uppercase tracking-[0.1em]">Revenue</p>
            <div class="space-y-0.5">
              <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                Deal Board
              </a>
              <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                Analytics
              </a>
            </div>
          </div>

          <!-- Engagement -->
          <div>
            <p class="px-3 py-1 text-[10px] font-semibold text-[var(--monarch-text-muted)] uppercase tracking-[0.1em]">Engagement</p>
            <div class="space-y-0.5">
              <a href="#" class="flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                <span class="flex-1">Agent Feed</span>
                <span class="px-1.5 py-0.5 rounded-full text-[9px] font-bold bg-[#EF4444] text-white">3</span>
              </a>
            </div>
          </div>
        </div>

        <!-- User -->
        <div class="flex items-center gap-3 px-5 py-3 border-t border-[var(--monarch-border-subtle)]">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-[var(--monarch-text-primary)] truncate">Joe Yared</p>
            <p class="text-xs text-[var(--monarch-text-muted)]">CEO</p>
          </div>
        </div>
      </div>
    </ComponentPreview>
  </section>
</DocsLayout>
