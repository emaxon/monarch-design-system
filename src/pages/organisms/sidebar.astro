---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Sidebar" description="The primary navigation structure — grouped sections, collapsible areas, and user profile.">

  <section class="mb-12">
    <ComponentPreview title="Application Sidebar" code='<aside class="monarch-sidebar">
  <div class="monarch-sidebar__header">
    <!-- Logo -->
  </div>
  <nav class="monarch-sidebar__nav">
    <div class="monarch-nav-section">
      <div class="monarch-nav-section__title">Intelligence</div>
      <div class="monarch-nav-section__items">
        <a class="monarch-nav-item monarch-nav-item--active" href="#">
          <svg class="monarch-nav-item__icon">...</svg>
          <span class="monarch-nav-item__label">Dashboard</span>
        </a>
      </div>
    </div>
  </nav>
  <div class="monarch-sidebar__footer">...</div>
</aside>'>
      <div class="monarch-sidebar" style="border-radius: 12px; overflow: hidden; width: 240px;">
        <div class="monarch-sidebar__header">
          <div style="width: 28px; height: 28px; border-radius: 7px; background: linear-gradient(135deg, #7C55F5, #AB76E2); display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F7F5F3" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" /><path d="M5 21h14" /></svg>
          </div>
          <span style="font-size: var(--monarch-text-base); font-weight: 600;">Monarch</span>
        </div>

        <nav class="monarch-sidebar__nav">
          <div class="monarch-nav-section">
            <div class="monarch-nav-section__title">Intelligence</div>
            <div class="monarch-nav-section__items">
              <a class="monarch-nav-item monarch-nav-item--active" href="#" style="text-decoration:none;">
                <svg class="monarch-nav-item__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                <span class="monarch-nav-item__label">Dashboard</span>
              </a>
              <a class="monarch-nav-item" href="#" style="text-decoration:none;">
                <svg class="monarch-nav-item__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                <span class="monarch-nav-item__label">Morning Brief</span>
              </a>
              <a class="monarch-nav-item" href="#" style="text-decoration:none;">
                <svg class="monarch-nav-item__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                <span class="monarch-nav-item__label">Signal Graph</span>
              </a>
            </div>
          </div>

          <div class="monarch-nav-section">
            <div class="monarch-nav-section__title">Data Engine</div>
            <div class="monarch-nav-section__items">
              <a class="monarch-nav-item" href="#" style="text-decoration:none;">
                <svg class="monarch-nav-item__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                <span class="monarch-nav-item__label">Accounts</span>
              </a>
            </div>
          </div>

          <div class="monarch-nav-section">
            <div class="monarch-nav-section__title">Revenue</div>
            <div class="monarch-nav-section__items">
              <a class="monarch-nav-item" href="#" style="text-decoration:none;">
                <svg class="monarch-nav-item__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                <span class="monarch-nav-item__label">Deal Board</span>
              </a>
              <a class="monarch-nav-item" href="#" style="text-decoration:none;">
                <svg class="monarch-nav-item__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                <span class="monarch-nav-item__label">Analytics</span>
              </a>
            </div>
          </div>

          <div class="monarch-nav-section">
            <div class="monarch-nav-section__title">Engagement</div>
            <div class="monarch-nav-section__items">
              <a class="monarch-nav-item" href="#" style="text-decoration:none;">
                <svg class="monarch-nav-item__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2" /></svg>
                <span class="monarch-nav-item__label">Agent Feed</span>
                <span class="monarch-nav-item__badge">3</span>
              </a>
            </div>
          </div>
        </nav>

        <div class="monarch-sidebar__footer">
          <div class="monarch-avatar monarch-avatar-sm monarch-avatar-brand">JY</div>
          <div>
            <div style="font-size: var(--monarch-text-sm); font-weight: 500;">Joe Yared</div>
            <div style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">CEO</div>
          </div>
        </div>
      </div>
    </ComponentPreview>
  </section>
</DocsLayout>
