---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Chat Interface" description="Conversational AI component — the foundation for Monarch's LLM experiences.">

  <section class="mb-12">
    <p style="color: var(--monarch-text-secondary); margin-bottom: 24px;">This organism previews the direction for conversational AI interfaces within Monarch — inspired by the push-based, daily engagement model where the LLM proactively guides users through workflows.</p>

    <ComponentPreview title="Agent Chat" background="elevated" previewStyle="background: radial-gradient(circle at 30% 50%, #7C55F5, transparent 70%), radial-gradient(circle at 70% 50%, #3B82F6, transparent 70%);" code='<div class="monarch-chat">
  <div class="monarch-chat__header">
    <div class="monarch-avatar monarch-avatar-md monarch-avatar-agent">
      <svg>🤖</svg>
      <span class="monarch-avatar__status monarch-avatar__status--online"></span>
    </div>
    <div class="monarch-chat__header-info">
      <div class="monarch-chat__header-name">Sonder Intelligence</div>
      <div class="monarch-chat__header-status">Your daily briefing agent</div>
    </div>
  </div>
  <div class="monarch-chat__messages">
    <div class="monarch-chat__bubble monarch-chat__bubble--agent">
      <div class="monarch-chat__bubble-avatar">
        <div class="monarch-avatar monarch-avatar-sm monarch-avatar-agent">...</div>
      </div>
      <div class="monarch-chat__bubble-content">
        <div class="monarch-chat__bubble-body">Good morning...</div>
        <span class="monarch-chat__bubble-time">8:00 AM</span>
      </div>
    </div>
    <div class="monarch-chat__bubble monarch-chat__bubble--user">
      <div class="monarch-chat__bubble-avatar">
        <div class="monarch-avatar monarch-avatar-sm monarch-avatar-brand">JY</div>
      </div>
      <div class="monarch-chat__bubble-content">
        <div class="monarch-chat__bubble-body">Question...</div>
        <span class="monarch-chat__bubble-time">8:02 AM</span>
      </div>
    </div>
    <div class="monarch-chat__typing">
      <div class="monarch-chat__typing-dots">
        <span class="monarch-chat__typing-dot"></span>
        <span class="monarch-chat__typing-dot"></span>
        <span class="monarch-chat__typing-dot"></span>
      </div>
    </div>
  </div>
  <div class="monarch-chat__prompts">
    <button class="monarch-chat__prompt-chip">Show at-risk deals</button>
  </div>
  <div class="monarch-chat__input-area">
    <input class="monarch-input" placeholder="Ask Monarch anything..." />
    <button class="monarch-chat__send-btn"><svg>→</svg></button>
  </div>
</div>'>
      <div class="monarch-chat" style="max-width: 32rem; margin: 0 auto;">
        <!-- Header -->
        <div class="monarch-chat__header">
          <div style="position: relative;">
            <div class="monarch-avatar monarch-avatar-md monarch-avatar-agent">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              <span class="monarch-avatar__status monarch-avatar__status--online"></span>
            </div>
          </div>
          <div class="monarch-chat__header-info">
            <div class="monarch-chat__header-name">Sonder Intelligence</div>
            <div class="monarch-chat__header-status">Your daily briefing agent</div>
          </div>
          <button class="monarch-btn monarch-btn-ghost monarch-btn-icon">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" /></svg>
          </button>
        </div>

        <!-- Messages -->
        <div class="monarch-chat__messages">
          <!-- Agent message -->
          <div class="monarch-chat__bubble monarch-chat__bubble--agent">
            <div class="monarch-chat__bubble-avatar">
              <div class="monarch-avatar monarch-avatar-sm monarch-avatar-agent">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
            </div>
            <div class="monarch-chat__bubble-content">
              <div class="monarch-chat__bubble-body">
                <p>Good morning, Joe. ☀️ Here's your 2-minute briefing:</p>
                <div style="margin-top: 12px; display: flex; flex-direction: column; gap: 8px;">
                  <div style="display: flex; align-items: flex-start; gap: 8px;"><span style="font-size: 12px; margin-top: 2px;">🔴</span><p><strong>AK Design Group</strong> has stalled in Negotiation for 28 days. Last contact was a pricing objection.</p></div>
                  <div style="display: flex; align-items: flex-start; gap: 8px;"><span style="font-size: 12px; margin-top: 2px;">📈</span><p><strong>11 high-intent accounts</strong> detected overnight matching your ICP. Auto-enriched and scored.</p></div>
                  <div style="display: flex; align-items: flex-start; gap: 8px;"><span style="font-size: 12px; margin-top: 2px;">✅</span><p><strong>47 personalized emails</strong> sent to The Kitchen Source - Dallas. 12 opened, 3 clicked pricing.</p></div>
                </div>
              </div>
              <span class="monarch-chat__bubble-time">8:00 AM</span>
            </div>
          </div>

          <!-- User message -->
          <div class="monarch-chat__bubble monarch-chat__bubble--user">
            <div class="monarch-chat__bubble-avatar">
              <div class="monarch-avatar monarch-avatar-sm monarch-avatar-brand">JY</div>
            </div>
            <div class="monarch-chat__bubble-content">
              <div class="monarch-chat__bubble-body">What's the recommended next step for AK Design Group?</div>
              <span class="monarch-chat__bubble-time">8:02 AM</span>
            </div>
          </div>

          <!-- Agent response with actions -->
          <div class="monarch-chat__bubble monarch-chat__bubble--agent">
            <div class="monarch-chat__bubble-avatar">
              <div class="monarch-avatar monarch-avatar-sm monarch-avatar-agent">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
            </div>
            <div class="monarch-chat__bubble-content">
              <div class="monarch-chat__bubble-body">
                <p>Based on the pricing objection pattern, I recommend:</p>
                <ol style="margin-top: 8px; display: flex; flex-direction: column; gap: 6px;">
                  <li style="display: flex; gap: 8px;"><span style="color: var(--monarch-brand-violet); font-weight: 600;">1.</span> Send the ROI calculator showing projected savings over 24 months</li>
                  <li style="display: flex; gap: 8px;"><span style="color: var(--monarch-brand-violet); font-weight: 600;">2.</span> Schedule an executive sponsor call within the week</li>
                </ol>
                <div class="monarch-chat__actions">
                  <button class="monarch-btn monarch-btn-primary monarch-btn-sm">Send ROI Calculator</button>
                  <button class="monarch-btn monarch-btn-outline monarch-btn-sm">Schedule Call</button>
                </div>
              </div>
              <span class="monarch-chat__bubble-time">8:02 AM</span>
            </div>
          </div>

          <!-- Typing indicator -->
          <div class="monarch-chat__typing">
            <div class="monarch-chat__bubble-avatar">
              <div class="monarch-avatar monarch-avatar-sm monarch-avatar-agent">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
            </div>
            <div class="monarch-chat__typing-dots">
              <span class="monarch-chat__typing-dot"></span>
              <span class="monarch-chat__typing-dot"></span>
              <span class="monarch-chat__typing-dot"></span>
            </div>
          </div>
        </div>

        <!-- Suggested Prompts -->
        <div class="monarch-chat__prompts">
          <button class="monarch-chat__prompt-chip">Show at-risk deals</button>
          <button class="monarch-chat__prompt-chip">Weekly pipeline summary</button>
          <button class="monarch-chat__prompt-chip">Agent performance</button>
        </div>

        <!-- Input -->
        <div class="monarch-chat__input-area">
          <input class="monarch-input" placeholder="Ask Sonder anything..." />
          <button class="monarch-chat__send-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
          </button>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Cambria LLM Direction</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="monarch-card"><div class="monarch-card__body">
        <h4 style="font-weight: 600; color: var(--monarch-brand-violet); margin-bottom: 8px;">Give-to-Get Exchange</h4>
        <p style="font-size: var(--monarch-text-sm); color: var(--monarch-text-secondary);">Employees answer the agent's daily questions and immediately get valuable insights back — not a one-way data extraction.</p>
      </div></div>
      <div class="monarch-card"><div class="monarch-card__body">
        <h4 style="font-weight: 600; color: #E0B2B3; margin-bottom: 8px;">Push, Not Pull</h4>
        <p style="font-size: var(--monarch-text-sm); color: var(--monarch-text-secondary);">The LLM proactively surfaces what matters. Users don't need to know what to ask — the agent leads the conversation.</p>
      </div></div>
      <div class="monarch-card"><div class="monarch-card__body">
        <h4 style="font-weight: 600; color: #3B82F6; margin-bottom: 8px;">Action, Not Information</h4>
        <p style="font-size: var(--monarch-text-sm); color: var(--monarch-text-secondary);">Every AI response should enable action — send the email, schedule the call, update the deal — not just report status.</p>
      </div></div>
      <div class="monarch-card"><div class="monarch-card__body">
        <h4 style="font-weight: 600; color: #22C55E; margin-bottom: 8px;">Progress Signals</h4>
        <p style="font-size: var(--monarch-text-sm); color: var(--monarch-text-secondary);">Subtle progress indicators that reward daily engagement without gamification excess.</p>
      </div></div>
    </div>
  </section>
</DocsLayout>
