---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Chat Interface" description="Conversational AI component — the foundation for Monarch's LLM experiences.">

  <section class="mb-12">
    <p class="text-[var(--monarch-text-secondary)] mb-6">This organism previews the direction for conversational AI interfaces within Monarch — inspired by the push-based, daily engagement model where the LLM proactively guides users through workflows.</p>

    <ComponentPreview title="Agent Chat">
      <div class="max-w-lg mx-auto rounded-xl bg-[var(--monarch-bg-surface)] border border-[var(--monarch-border-subtle)] overflow-hidden shadow-[var(--monarch-shadow-lg)]">
        <!-- Chat Header -->
        <div class="flex items-center gap-3 px-5 py-3 border-b border-[var(--monarch-border-subtle)]">
          <div class="relative">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background: var(--monarch-brand-gradient-subtle);">
              <svg class="w-5 h-5 text-[var(--monarch-brand-purple)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <span class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full bg-[#22C55E] border-2 border-[var(--monarch-bg-surface)]"></span>
          </div>
          <div class="flex-1">
            <p class="text-sm font-semibold">Monarch Intelligence</p>
            <p class="text-xs text-[var(--monarch-text-muted)]">Your daily briefing agent</p>
          </div>
          <button class="w-8 h-8 rounded-lg flex items-center justify-center text-[var(--monarch-text-muted)] hover:bg-[var(--monarch-bg-elevated)] transition-colors duration-200">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" /></svg>
          </button>
        </div>

        <!-- Messages -->
        <div class="p-5 space-y-5 max-h-80 overflow-y-auto">
          <!-- Agent message -->
          <div class="flex gap-3">
            <div class="w-7 h-7 rounded-lg shrink-0 flex items-center justify-center mt-0.5" style="background: var(--monarch-brand-gradient-subtle);">
              <svg class="w-3.5 h-3.5 text-[var(--monarch-brand-purple)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div class="flex-1 space-y-3">
              <div class="p-3.5 rounded-xl rounded-tl-sm bg-[var(--monarch-bg-elevated)] border border-[var(--monarch-border-subtle)]">
                <p class="text-sm text-[var(--monarch-text-primary)] leading-relaxed">Good morning, Joe. ☀️ Here's your 2-minute briefing:</p>
                <div class="mt-3 space-y-2">
                  <div class="flex items-start gap-2">
                    <span class="text-xs mt-0.5">🔴</span>
                    <p class="text-sm text-[var(--monarch-text-secondary)]"><strong class="text-[var(--monarch-text-primary)]">AK Design Group</strong> has stalled in Negotiation for 28 days. Last contact was a pricing objection.</p>
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="text-xs mt-0.5">📈</span>
                    <p class="text-sm text-[var(--monarch-text-secondary)]"><strong class="text-[var(--monarch-text-primary)]">11 high-intent accounts</strong> detected overnight matching your ICP. Auto-enriched and scored.</p>
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="text-xs mt-0.5">✅</span>
                    <p class="text-sm text-[var(--monarch-text-secondary)]"><strong class="text-[var(--monarch-text-primary)]">47 personalized emails</strong> sent to The Kitchen Source - Dallas. 12 opened, 3 clicked pricing.</p>
                  </div>
                </div>
              </div>
              <p class="text-[10px] text-[var(--monarch-text-muted)]">8:00 AM</p>
            </div>
          </div>

          <!-- User message -->
          <div class="flex gap-3 flex-row-reverse">
            <div class="w-7 h-7 rounded-full shrink-0 flex items-center justify-center text-[10px] font-semibold text-white mt-0.5" style="background: var(--monarch-brand-gradient);">JY</div>
            <div class="flex-1 flex flex-col items-end space-y-1">
              <div class="p-3.5 rounded-xl rounded-tr-sm text-sm text-white max-w-[85%]" style="background: var(--monarch-brand-gradient);">
                What's the recommended next step for AK Design Group?
              </div>
              <p class="text-[10px] text-[var(--monarch-text-muted)]">8:02 AM</p>
            </div>
          </div>

          <!-- Agent response -->
          <div class="flex gap-3">
            <div class="w-7 h-7 rounded-lg shrink-0 flex items-center justify-center mt-0.5" style="background: var(--monarch-brand-gradient-subtle);">
              <svg class="w-3.5 h-3.5 text-[var(--monarch-brand-purple)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div class="flex-1 space-y-3">
              <div class="p-3.5 rounded-xl rounded-tl-sm bg-[var(--monarch-bg-elevated)] border border-[var(--monarch-border-subtle)]">
                <p class="text-sm text-[var(--monarch-text-secondary)] leading-relaxed">Based on the pricing objection pattern, I recommend a two-step approach:</p>
                <ol class="mt-2 space-y-1.5 text-sm text-[var(--monarch-text-secondary)]">
                  <li class="flex gap-2"><span class="text-[var(--monarch-brand-purple)] font-semibold">1.</span> Send the ROI calculator showing projected savings over 24 months</li>
                  <li class="flex gap-2"><span class="text-[var(--monarch-brand-purple)] font-semibold">2.</span> Schedule an executive sponsor call within the week</li>
                </ol>
                <div class="flex gap-2 mt-3">
                  <button class="px-3 py-1.5 rounded-lg text-xs font-semibold text-white" style="background: var(--monarch-brand-gradient);">Send ROI Calculator</button>
                  <button class="px-3 py-1.5 rounded-lg text-xs font-semibold border border-[var(--monarch-border-medium)] text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-base)] transition-colors duration-200">Schedule Call</button>
                </div>
              </div>
              <p class="text-[10px] text-[var(--monarch-text-muted)]">8:02 AM</p>
            </div>
          </div>

          <!-- Typing indicator -->
          <div class="flex gap-3">
            <div class="w-7 h-7 rounded-lg shrink-0 flex items-center justify-center" style="background: var(--monarch-brand-gradient-subtle);">
              <svg class="w-3.5 h-3.5 text-[var(--monarch-brand-purple)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div class="p-3 rounded-xl rounded-tl-sm bg-[var(--monarch-bg-elevated)] border border-[var(--monarch-border-subtle)]">
              <div class="flex gap-1">
                <span class="w-2 h-2 rounded-full bg-[var(--monarch-text-muted)]" style="animation: monarch-typing-dot 1.4s ease-in-out infinite;"></span>
                <span class="w-2 h-2 rounded-full bg-[var(--monarch-text-muted)]" style="animation: monarch-typing-dot 1.4s ease-in-out infinite 0.2s;"></span>
                <span class="w-2 h-2 rounded-full bg-[var(--monarch-text-muted)]" style="animation: monarch-typing-dot 1.4s ease-in-out infinite 0.4s;"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Suggested Prompts -->
        <div class="px-5 py-2 border-t border-[var(--monarch-border-subtle)]">
          <div class="flex gap-2 overflow-x-auto pb-1">
            <button class="shrink-0 px-3 py-1.5 rounded-full text-xs font-medium border border-[var(--monarch-border-subtle)] text-[var(--monarch-text-secondary)] hover:border-[var(--monarch-brand-purple)] hover:text-[var(--monarch-brand-purple)] transition-all duration-200">Show at-risk deals</button>
            <button class="shrink-0 px-3 py-1.5 rounded-full text-xs font-medium border border-[var(--monarch-border-subtle)] text-[var(--monarch-text-secondary)] hover:border-[var(--monarch-brand-purple)] hover:text-[var(--monarch-brand-purple)] transition-all duration-200">Weekly pipeline summary</button>
            <button class="shrink-0 px-3 py-1.5 rounded-full text-xs font-medium border border-[var(--monarch-border-subtle)] text-[var(--monarch-text-secondary)] hover:border-[var(--monarch-brand-purple)] hover:text-[var(--monarch-brand-purple)] transition-all duration-200">Agent performance</button>
          </div>
        </div>

        <!-- Input Area -->
        <div class="px-5 py-3 border-t border-[var(--monarch-border-subtle)]">
          <div class="flex items-center gap-2">
            <input type="text" placeholder="Ask Monarch anything..." class="flex-1 px-4 py-2.5 rounded-lg bg-[var(--monarch-bg-elevated)] border border-[var(--monarch-border-subtle)] text-sm text-[var(--monarch-text-primary)] placeholder-[var(--monarch-text-muted)] focus:outline-none focus:border-[var(--monarch-brand-purple)] focus:ring-2 focus:ring-[rgba(124,58,237,0.2)] transition-all duration-200" />
            <button class="w-10 h-10 rounded-lg flex items-center justify-center text-white shrink-0 transition-all duration-200 hover:shadow-[0_0_15px_rgba(124,58,237,0.3)]" style="background: var(--monarch-brand-gradient);">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
            </button>
          </div>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Design Decisions</h2>
    <div class="space-y-3 text-[var(--monarch-text-secondary)]">
      <p>• <strong>AI = square avatar</strong>, User = round avatar — instant visual differentiation</p>
      <p>• Agent messages: <strong>elevated background with subtle border</strong> — distinct from user's gradient messages</p>
      <p>• User messages: <strong>brand gradient</strong> — the user's voice is the hero</p>
      <p>• <strong>Inline action buttons</strong> within AI responses — the agent can drive action, not just inform</p>
      <p>• <strong>Suggested prompts</strong> as horizontal chips — reduces blank-page anxiety, guides daily interaction</p>
      <p>• <strong>Typing indicator</strong> with bouncing dots — signals the agent is working</p>
      <p>• Push-first model: the agent <strong>proactively briefs</strong> rather than waiting for questions</p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Cambria LLM Direction</h2>
    <p class="text-[var(--monarch-text-secondary)] mb-4">This component establishes the visual foundation for the "5-minute daily" LLM experience. Key UX principles:</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="monarch-card p-5">
        <h4 class="font-semibold text-[var(--monarch-brand-purple)] mb-2">Give-to-Get Exchange</h4>
        <p class="text-sm text-[var(--monarch-text-secondary)]">Employees answer the agent's daily questions and immediately get valuable insights back — not a one-way data extraction.</p>
      </div>
      <div class="monarch-card p-5">
        <h4 class="font-semibold text-[#EC4899] mb-2">Push, Not Pull</h4>
        <p class="text-sm text-[var(--monarch-text-secondary)]">The LLM proactively surfaces what matters. Users don't need to know what to ask — the agent leads the conversation.</p>
      </div>
      <div class="monarch-card p-5">
        <h4 class="font-semibold text-[#3B82F6] mb-2">Action, Not Information</h4>
        <p class="text-sm text-[var(--monarch-text-secondary)]">Every AI response should enable action — send the email, schedule the call, update the deal — not just report status.</p>
      </div>
      <div class="monarch-card p-5">
        <h4 class="font-semibold text-[#22C55E] mb-2">Progress Signals</h4>
        <p class="text-sm text-[var(--monarch-text-secondary)]">Subtle progress indicators (streaks, completion, impact metrics) that reward daily engagement without gamification excess.</p>
      </div>
    </div>
  </section>
</DocsLayout>
