---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Kanban Board" description="Deal pipeline visualization — columns with health-scored cards.">

  <section class="mb-12">
    <ComponentPreview title="Deal Board" code='<div class="monarch-kanban">
  <div class="monarch-kanban__column">
    <div class="monarch-kanban__column-header">
      <div class="monarch-kanban__column-title">
        Prospecting <span class="monarch-kanban__column-count">3</span>
      </div>
      <span class="monarch-kanban__column-total">$445K</span>
    </div>
    <div class="monarch-kanban__column-body">
      <div class="monarch-kanban__card">
        <div class="monarch-kanban__card-header">
          <span class="monarch-kanban__card-title">Renovation - Baltix</span>
          <!-- health ring -->
        </div>
        <div class="monarch-kanban__card-footer">
          <span class="monarch-kanban__card-value">$154,527</span>
          <span class="monarch-badge monarch-badge-danger monarch-badge-sm">45d</span>
        </div>
      </div>
    </div>
  </div>
</div>'>
      <div class="monarch-kanban">
        <!-- Prospecting -->
        <div class="monarch-kanban__column">
          <div class="monarch-kanban__column-header">
            <div class="monarch-kanban__column-title">Prospecting <span class="monarch-kanban__column-count">2</span></div>
            <span class="monarch-kanban__column-total">$291K</span>
          </div>
          <div class="monarch-kanban__column-body">
            <div class="monarch-kanban__card">
              <div class="monarch-kanban__card-header">
                <span class="monarch-kanban__card-title">Renovation - Baltix</span>
                <div class="monarch-health-ring monarch-health-ring-sm"><svg class="monarch-health-ring__svg" viewBox="0 0 36 36"><path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" /><path class="monarch-health-ring__fill monarch-health-ring__fill--critical" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="25, 100" /></svg></div>
              </div>
              <div class="monarch-kanban__card-footer">
                <span class="monarch-kanban__card-value">$154,527</span>
                <span class="monarch-badge monarch-badge-danger monarch-badge-sm">45d</span>
              </div>
            </div>
            <div class="monarch-kanban__card">
              <div class="monarch-kanban__card-header">
                <span class="monarch-kanban__card-title">Upgrade - Top</span>
                <div class="monarch-health-ring monarch-health-ring-sm"><svg class="monarch-health-ring__svg" viewBox="0 0 36 36"><path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" /><path class="monarch-health-ring__fill monarch-health-ring__fill--critical" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="25, 100" /></svg></div>
              </div>
              <div class="monarch-kanban__card-footer">
                <span class="monarch-kanban__card-value">$136,201</span>
                <span class="monarch-badge monarch-badge-danger monarch-badge-sm">62d</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Qualification -->
        <div class="monarch-kanban__column">
          <div class="monarch-kanban__column-header">
            <div class="monarch-kanban__column-title">Qualification <span class="monarch-kanban__column-count">2</span></div>
            <span class="monarch-kanban__column-total">$661K</span>
          </div>
          <div class="monarch-kanban__column-body">
            <div class="monarch-kanban__card">
              <div class="monarch-kanban__card-header">
                <span class="monarch-kanban__card-title">Build-Out - Baltix</span>
                <div class="monarch-health-ring monarch-health-ring-sm"><svg class="monarch-health-ring__svg" viewBox="0 0 36 36"><path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" /><path class="monarch-health-ring__fill monarch-health-ring__fill--warning" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="65, 100" /></svg></div>
              </div>
              <div class="monarch-kanban__card-footer">
                <span class="monarch-kanban__card-value">$308,793</span>
                <span class="monarch-badge monarch-badge-info monarch-badge-sm">2d</span>
              </div>
            </div>
            <div class="monarch-kanban__card">
              <div class="monarch-kanban__card-header">
                <span class="monarch-kanban__card-title">Build-Out - NBBJ</span>
                <div class="monarch-health-ring monarch-health-ring-sm"><svg class="monarch-health-ring__svg" viewBox="0 0 36 36"><path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" /><path class="monarch-health-ring__fill monarch-health-ring__fill--healthy" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="78, 100" /></svg></div>
              </div>
              <div class="monarch-kanban__card-footer">
                <span class="monarch-kanban__card-value">$351,978</span>
                <span class="monarch-badge monarch-badge-success monarch-badge-sm">10d</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Negotiation -->
        <div class="monarch-kanban__column">
          <div class="monarch-kanban__column-header">
            <div class="monarch-kanban__column-title">Negotiation <span class="monarch-kanban__column-count">1</span></div>
            <span class="monarch-kanban__column-total">$286K</span>
          </div>
          <div class="monarch-kanban__column-body">
            <div class="monarch-kanban__card">
              <div class="monarch-kanban__card-header">
                <span class="monarch-kanban__card-title">Design - Calnitsky</span>
                <div class="monarch-health-ring monarch-health-ring-sm"><svg class="monarch-health-ring__svg" viewBox="0 0 36 36"><path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" /><path class="monarch-health-ring__fill monarch-health-ring__fill--warning" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="42, 100" /></svg></div>
              </div>
              <div class="monarch-kanban__card-footer">
                <span class="monarch-kanban__card-value">$285,852</span>
                <span class="monarch-badge monarch-badge-warning monarch-badge-sm">40d</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ComponentPreview>
  </section>
</DocsLayout>
