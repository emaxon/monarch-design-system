---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Toggles" description="Switches and checkboxes for binary choices and settings.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Switch Toggle</h2>

    <ComponentPreview title="Toggle Switches" code='<div class="monarch-toggle-row">
  <div>
    <div class="monarch-toggle-row__label">Auto-enrich</div>
    <div class="monarch-toggle-row__description">Enrich new accounts</div>
  </div>
  <div class="monarch-toggle monarch-toggle--active">
    <span class="monarch-toggle__thumb"></span>
  </div>
</div>'>
      <div class="space-y-6 max-w-sm">
        <div class="monarch-toggle-row">
          <div>
            <div class="monarch-toggle-row__label">Auto-enrich new accounts</div>
            <div class="monarch-toggle-row__description">Automatically run data enrichment on incoming accounts</div>
          </div>
          <div class="monarch-toggle monarch-toggle--active">
            <span class="monarch-toggle__thumb"></span>
          </div>
        </div>
        <div class="monarch-toggle-row">
          <div>
            <div class="monarch-toggle-row__label">Email notifications</div>
            <div class="monarch-toggle-row__description">Send email alerts for deal status changes</div>
          </div>
          <div class="monarch-toggle">
            <span class="monarch-toggle__thumb"></span>
          </div>
        </div>
        <div class="monarch-toggle-row" style="opacity: 0.5;">
          <div>
            <div class="monarch-toggle-row__label">Ghost Rep mode</div>
            <div class="monarch-toggle-row__description">Requires Enterprise plan</div>
          </div>
          <div class="monarch-toggle monarch-toggle--disabled">
            <span class="monarch-toggle__thumb"></span>
          </div>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Checkboxes</h2>

    <ComponentPreview title="Styled Checkboxes" code='<label class="monarch-checkbox">
  <div class="monarch-checkbox__box monarch-checkbox__box--checked">
    <svg>✓</svg>
  </div>
  <span class="monarch-checkbox__label">Intelligence Agent</span>
</label>'>
      <div class="space-y-3 max-w-sm">
        <label class="monarch-checkbox">
          <div class="monarch-checkbox__box monarch-checkbox__box--checked">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
          </div>
          <span class="monarch-checkbox__label">Intelligence Agent</span>
        </label>
        <label class="monarch-checkbox">
          <div class="monarch-checkbox__box monarch-checkbox__box--checked">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
          </div>
          <span class="monarch-checkbox__label">Engagement Agent</span>
        </label>
        <label class="monarch-checkbox">
          <div class="monarch-checkbox__box"></div>
          <span class="monarch-checkbox__label monarch-checkbox__label--unchecked">Revenue Agent</span>
        </label>
        <label class="monarch-checkbox">
          <div class="monarch-checkbox__box"></div>
          <span class="monarch-checkbox__label monarch-checkbox__label--unchecked">Success Agent</span>
        </label>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Interactive Toggle</h2>

    <ComponentPreview title="Click to Toggle">
      <div class="flex items-center gap-4">
        <div id="demo-toggle" class="monarch-toggle monarch-toggle-lg" onclick="this.classList.toggle('monarch-toggle--active');">
          <span class="monarch-toggle__thumb"></span>
        </div>
        <span style="font-size: var(--monarch-text-sm); color: var(--monarch-text-secondary);">Click to toggle</span>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Usage Guidelines</h2>
    <div class="space-y-3" style="color: var(--monarch-text-secondary);">
      <p>• Use <strong>toggles</strong> for immediate on/off settings — no save button needed</p>
      <p>• Use <strong>checkboxes</strong> for multi-select lists where choices are submitted together</p>
      <p>• Active state uses <strong>brand indigo</strong> — instantly recognizable</p>
      <p>• Include a <strong>label and description</strong> next to toggles for clarity</p>
      <p>• Disabled toggles show <strong>50% opacity</strong> with a reason</p>
    </div>
  </section>
</DocsLayout>
