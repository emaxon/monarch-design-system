---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Buttons" description="Primary actions, secondary options, and ghost interactions. Every button earns its place.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Variants</h2>

    <ComponentPreview title="Button Types" code='<button class="monarch-btn monarch-btn-primary">Primary</button>
<button class="monarch-btn monarch-btn-secondary">Secondary</button>
<button class="monarch-btn monarch-btn-ghost">Ghost</button>
<button class="monarch-btn monarch-btn-danger">Danger</button>'>
      <div class="flex flex-wrap items-center gap-4">
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-white transition-all duration-200 hover:shadow-[0_0_20px_rgba(124,58,237,0.3)] hover:scale-[1.02] active:scale-[0.98]" style="background: var(--monarch-brand-gradient);">
          Primary
        </button>
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold border border-[var(--monarch-brand-purple)] text-[var(--monarch-brand-purple)] hover:bg-[rgba(124,58,237,0.1)] transition-all duration-200 active:scale-[0.98]">
          Secondary
        </button>
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200 active:scale-[0.98]">
          Ghost
        </button>
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold bg-[var(--monarch-danger-dim)] text-[var(--monarch-danger)] hover:bg-[rgba(239,68,68,0.25)] transition-all duration-200 active:scale-[0.98]">
          Danger
        </button>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Sizes</h2>

    <ComponentPreview title="Button Sizes">
      <div class="flex flex-wrap items-center gap-4">
        <button class="inline-flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-semibold text-white" style="background: var(--monarch-brand-gradient);">
          Small
        </button>
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-white" style="background: var(--monarch-brand-gradient);">
          Medium
        </button>
        <button class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-base font-semibold text-white" style="background: var(--monarch-brand-gradient);">
          Large
        </button>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">With Icons</h2>

    <ComponentPreview title="Icon Buttons">
      <div class="flex flex-wrap items-center gap-4">
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-white transition-all duration-200 hover:shadow-[0_0_20px_rgba(124,58,237,0.3)]" style="background: var(--monarch-brand-gradient);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          Add Account
        </button>
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold border border-[var(--monarch-border-medium)] text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          Export
        </button>
        <button class="inline-flex items-center justify-center w-10 h-10 rounded-lg text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] transition-all duration-200">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" /></svg>
        </button>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">States</h2>

    <ComponentPreview title="Loading & Disabled">
      <div class="flex flex-wrap items-center gap-4">
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-white" style="background: var(--monarch-brand-gradient);">
          <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Saving...
        </button>
        <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-white opacity-50 cursor-not-allowed" style="background: var(--monarch-brand-gradient);" disabled>
          Disabled
        </button>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Variants Table</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-[var(--monarch-border-subtle)]">
            <th class="text-left py-3 pr-4 text-[var(--monarch-text-muted)] font-medium">Variant</th>
            <th class="text-left py-3 pr-4 text-[var(--monarch-text-muted)] font-medium">Use When</th>
            <th class="text-left py-3 text-[var(--monarch-text-muted)] font-medium">Class</th>
          </tr>
        </thead>
        <tbody class="text-[var(--monarch-text-secondary)]">
          <tr class="border-b border-[var(--monarch-border-subtle)]">
            <td class="py-3 pr-4 font-medium text-[var(--monarch-text-primary)]">Primary</td>
            <td class="py-3 pr-4">Main CTA — one per visible area. Save, Submit, Create.</td>
            <td class="py-3 font-mono text-xs">.monarch-btn-primary</td>
          </tr>
          <tr class="border-b border-[var(--monarch-border-subtle)]">
            <td class="py-3 pr-4 font-medium text-[var(--monarch-text-primary)]">Secondary</td>
            <td class="py-3 pr-4">Supporting action alongside primary. Cancel, View Details.</td>
            <td class="py-3 font-mono text-xs">.monarch-btn-secondary</td>
          </tr>
          <tr class="border-b border-[var(--monarch-border-subtle)]">
            <td class="py-3 pr-4 font-medium text-[var(--monarch-text-primary)]">Ghost</td>
            <td class="py-3 pr-4">Tertiary actions, toolbar items, minimal footprint.</td>
            <td class="py-3 font-mono text-xs">.monarch-btn-ghost</td>
          </tr>
          <tr>
            <td class="py-3 pr-4 font-medium text-[var(--monarch-text-primary)]">Danger</td>
            <td class="py-3 pr-4">Destructive actions — Delete, Remove, Disconnect.</td>
            <td class="py-3 font-mono text-xs">.monarch-btn-danger</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</DocsLayout>
