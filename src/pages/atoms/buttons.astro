---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Buttons" description="Primary actions, secondary options, and ghost interactions. Every button earns its place.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Variants</h2>

    <ComponentPreview title="Button Types" code='<button class="monarch-btn monarch-btn-primary">Primary</button>
<button class="monarch-btn monarch-btn-secondary">Secondary</button>
<button class="monarch-btn monarch-btn-ghost">Ghost</button>
<button class="monarch-btn monarch-btn-danger">Danger</button>
<button class="monarch-btn monarch-btn-outline">Outline</button>'>
      <div class="flex flex-wrap items-center gap-4">
        <button class="monarch-btn monarch-btn-primary">Primary</button>
        <button class="monarch-btn monarch-btn-secondary">Secondary</button>
        <button class="monarch-btn monarch-btn-ghost">Ghost</button>
        <button class="monarch-btn monarch-btn-danger">Danger</button>
        <button class="monarch-btn monarch-btn-outline">Outline</button>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Sizes</h2>

    <ComponentPreview title="Button Sizes" code='<button class="monarch-btn monarch-btn-primary monarch-btn-sm">Small</button>
<button class="monarch-btn monarch-btn-primary">Medium</button>
<button class="monarch-btn monarch-btn-primary monarch-btn-lg">Large</button>'>
      <div class="flex flex-wrap items-center gap-4">
        <button class="monarch-btn monarch-btn-primary monarch-btn-sm">Small</button>
        <button class="monarch-btn monarch-btn-primary">Medium</button>
        <button class="monarch-btn monarch-btn-primary monarch-btn-lg">Large</button>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">With Icons</h2>

    <ComponentPreview title="Icon Buttons" code='<button class="monarch-btn monarch-btn-primary">
  <svg>...</svg> Add Account
</button>
<button class="monarch-btn monarch-btn-outline">
  <svg>...</svg> Export
</button>
<button class="monarch-btn monarch-btn-ghost monarch-btn-icon">
  <svg>...</svg>
</button>'>
      <div class="flex flex-wrap items-center gap-4">
        <button class="monarch-btn monarch-btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          Add Account
        </button>
        <button class="monarch-btn monarch-btn-outline">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          Export
        </button>
        <button class="monarch-btn monarch-btn-ghost monarch-btn-icon">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" /></svg>
        </button>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">States</h2>

    <ComponentPreview title="Loading &amp; Disabled" code='<button class="monarch-btn monarch-btn-primary monarch-btn--loading">
  <svg class="monarch-btn__spinner">...</svg> Saving...
</button>
<button class="monarch-btn monarch-btn-primary" disabled>Disabled</button>'>
      <div class="flex flex-wrap items-center gap-4">
        <button class="monarch-btn monarch-btn-primary monarch-btn--loading">
          <svg class="monarch-btn__spinner w-4 h-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Saving...
        </button>
        <button class="monarch-btn monarch-btn-primary" disabled>Disabled</button>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Variants Table</h2>
    <div class="overflow-x-auto">
      <table class="monarch-table">
        <thead>
          <tr>
            <th>Variant</th>
            <th>Use When</th>
            <th>Class</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="font-medium">Primary</td><td>Main CTA — one per visible area. Save, Submit, Create.</td><td class="font-mono text-xs">.monarch-btn-primary</td></tr>
          <tr><td class="font-medium">Secondary</td><td>Supporting action alongside primary. Cancel, View Details.</td><td class="font-mono text-xs">.monarch-btn-secondary</td></tr>
          <tr><td class="font-medium">Ghost</td><td>Tertiary actions, toolbar items, minimal footprint.</td><td class="font-mono text-xs">.monarch-btn-ghost</td></tr>
          <tr><td class="font-medium">Danger</td><td>Destructive actions — Delete, Remove, Disconnect.</td><td class="font-mono text-xs">.monarch-btn-danger</td></tr>
          <tr><td class="font-medium">Outline</td><td>Neutral bordered actions — Export, View, secondary navigation.</td><td class="font-mono text-xs">.monarch-btn-outline</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</DocsLayout>
