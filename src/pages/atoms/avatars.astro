---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Avatars" description="User identification through initials, images, and status indicators.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Initials</h2>
    <p class="text-[var(--monarch-text-secondary)] mb-6">When no profile image is available, display user initials on a gradient background. This is the primary avatar style in Monarch.</p>

    <ComponentPreview title="Initials Avatars">
      <div class="flex items-center gap-4">
        <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
        <div class="w-12 h-12 rounded-full flex items-center justify-center text-base font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
        <div class="w-16 h-16 rounded-full flex items-center justify-center text-lg font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Color Variants</h2>

    <ComponentPreview title="Different Users">
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white bg-[#3B82F6]">EM</div>
        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white bg-[#22C55E]">KM</div>
        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white bg-[#F59E0B]">SD</div>
        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white bg-[#EC4899]">AR</div>
        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white bg-[#EF4444]">TK</div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">With Status</h2>

    <ComponentPreview title="Status Indicator">
      <div class="flex items-center gap-6">
        <div class="relative">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
          <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full bg-[#22C55E] border-2 border-[var(--monarch-bg-surface)]"></span>
        </div>
        <div class="relative">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white bg-[#3B82F6]">EM</div>
          <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full bg-[#F59E0B] border-2 border-[var(--monarch-bg-surface)]"></span>
        </div>
        <div class="relative">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white bg-[#22C55E]">KM</div>
          <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full bg-[var(--monarch-text-muted)] border-2 border-[var(--monarch-bg-surface)]"></span>
        </div>
        <div class="relative">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white bg-[#EF4444]">TK</div>
          <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full bg-[#EF4444] border-2 border-[var(--monarch-bg-surface)] animate-[monarch-pulse-dot_2s_ease-in-out_infinite]"></span>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Avatar Group</h2>

    <ComponentPreview title="Stacked Avatars">
      <div class="flex items-center">
        <div class="flex -space-x-2">
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-semibold text-white border-2 border-[var(--monarch-bg-surface)]" style="background: var(--monarch-brand-gradient);">JY</div>
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-semibold text-white bg-[#3B82F6] border-2 border-[var(--monarch-bg-surface)]">EM</div>
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-semibold text-white bg-[#22C55E] border-2 border-[var(--monarch-bg-surface)]">KM</div>
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-semibold text-white bg-[#F59E0B] border-2 border-[var(--monarch-bg-surface)]">SD</div>
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-xs font-medium text-[var(--monarch-text-secondary)] bg-[var(--monarch-bg-elevated)] border-2 border-[var(--monarch-bg-surface)]">+3</div>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Agent Avatar</h2>
    <p class="text-[var(--monarch-text-secondary)] mb-4">AI agents use a distinct avatar style — square with rounded corners, gradient background, and a bot icon.</p>

    <ComponentPreview title="AI Agent Avatars">
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--monarch-brand-gradient-subtle);">
          <svg class="w-5 h-5 text-[var(--monarch-brand-purple)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </div>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-[rgba(59,130,246,0.12)]">
          <svg class="w-5 h-5 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-[rgba(34,197,94,0.12)]">
          <svg class="w-5 h-5 text-[#22C55E]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Usage Guidelines</h2>
    <div class="space-y-3 text-[var(--monarch-text-secondary)]">
      <p>• <strong>Humans</strong> get round avatars. <strong>AI agents</strong> get rounded-square avatars</p>
      <p>• Use <strong>brand gradient</strong> for the primary/current user, solid colors for others</p>
      <p>• Status dots: <strong>green</strong> = online, <strong>amber</strong> = away, <strong>gray</strong> = offline, <strong>red pulse</strong> = alert</p>
      <p>• In groups, cap visible avatars at <strong>4-5</strong> with a "+N" overflow</p>
      <p>• Stacked avatars overlap by <strong>8px</strong> (-space-x-2) with a surface-colored border</p>
    </div>
  </section>
</DocsLayout>
