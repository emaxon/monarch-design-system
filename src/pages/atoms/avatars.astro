---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Avatars" description="User identification through initials, images, and status indicators.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Sizes</h2>

    <ComponentPreview title="Avatar Sizes" code='<div class="monarch-avatar monarch-avatar-sm monarch-avatar-brand">JY</div>
<div class="monarch-avatar monarch-avatar-md monarch-avatar-brand">JY</div>
<div class="monarch-avatar monarch-avatar-lg monarch-avatar-brand">JY</div>
<div class="monarch-avatar monarch-avatar-xl monarch-avatar-brand">JY</div>'>
      <div class="flex items-center gap-4">
        <div class="monarch-avatar monarch-avatar-sm monarch-avatar-brand">JY</div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-brand">JY</div>
        <div class="monarch-avatar monarch-avatar-lg monarch-avatar-brand">JY</div>
        <div class="monarch-avatar monarch-avatar-xl monarch-avatar-brand">JY</div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Color Variants</h2>

    <ComponentPreview title="Different Users" code='<div class="monarch-avatar monarch-avatar-md monarch-avatar-brand">JY</div>
<div class="monarch-avatar monarch-avatar-md monarch-avatar-blue">EM</div>
<div class="monarch-avatar monarch-avatar-md monarch-avatar-green">KM</div>'>
      <div class="flex items-center gap-4">
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-brand">JY</div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-blue">EM</div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-green">KM</div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-amber">SD</div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-pink">AR</div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-red">TK</div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">With Status</h2>

    <ComponentPreview title="Status Indicator" code='<div class="monarch-avatar monarch-avatar-md monarch-avatar-brand">
  JY
  <span class="monarch-avatar__status monarch-avatar__status--online"></span>
</div>'>
      <div class="flex items-center gap-6">
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-brand">JY<span class="monarch-avatar__status monarch-avatar__status--online"></span></div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-blue">EM<span class="monarch-avatar__status monarch-avatar__status--away"></span></div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-green">KM<span class="monarch-avatar__status monarch-avatar__status--offline"></span></div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-red">TK<span class="monarch-avatar__status monarch-avatar__status--alert"></span></div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Avatar Group</h2>

    <ComponentPreview title="Stacked Avatars" code='<div class="monarch-avatar-group">
  <div class="monarch-avatar monarch-avatar-sm monarch-avatar-brand">JY</div>
  <div class="monarch-avatar monarch-avatar-sm monarch-avatar-blue">EM</div>
  <div class="monarch-avatar monarch-avatar-sm monarch-avatar-group__overflow">+3</div>
</div>'>
      <div class="monarch-avatar-group">
        <div class="monarch-avatar monarch-avatar-sm monarch-avatar-brand">JY</div>
        <div class="monarch-avatar monarch-avatar-sm monarch-avatar-blue">EM</div>
        <div class="monarch-avatar monarch-avatar-sm monarch-avatar-green">KM</div>
        <div class="monarch-avatar monarch-avatar-sm monarch-avatar-amber">SD</div>
        <div class="monarch-avatar monarch-avatar-sm monarch-avatar-group__overflow" style="width:36px;height:36px;">+3</div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Agent Avatar</h2>

    <ComponentPreview title="AI Agent Avatars" code='<div class="monarch-avatar monarch-avatar-md monarch-avatar-agent">
  <svg>🤖</svg>
</div>'>
      <div class="flex items-center gap-4">
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-agent">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-agent-blue">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <div class="monarch-avatar monarch-avatar-md monarch-avatar-agent-green">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Usage Guidelines</h2>
    <div class="space-y-3" style="color: var(--monarch-text-secondary);">
      <p>• <strong>Humans</strong> get round avatars. <strong>AI agents</strong> get rounded-square avatars</p>
      <p>• Use <strong>brand gradient</strong> for the primary/current user, solid colors for others</p>
      <p>• Status dots: <strong>green</strong> = online, <strong>amber</strong> = away, <strong>gray</strong> = offline, <strong>red pulse</strong> = alert</p>
      <p>• In groups, cap visible avatars at <strong>4-5</strong> with a "+N" overflow</p>
    </div>
  </section>
</DocsLayout>
