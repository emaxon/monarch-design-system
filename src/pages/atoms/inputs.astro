---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Inputs" description="Text fields, search bars, selects, and textareas. Clean focus states with brand-colored rings.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Text Input</h2>

    <ComponentPreview title="Text Inputs" code='<label class="monarch-label">Account Name</label>
<input class="monarch-input" placeholder="Enter account name..." />

<label class="monarch-label monarch-label--error">Company (required)</label>
<input class="monarch-input monarch-input--error" />
<p class="monarch-helper monarch-helper--error">This field is required</p>'>
      <div class="space-y-4 max-w-md">
        <div>
          <label class="monarch-label">Account Name</label>
          <input class="monarch-input" placeholder="Enter account name..." />
        </div>
        <div>
          <label class="monarch-label">Email</label>
          <input class="monarch-input" value="joe@monarch.tech" />
        </div>
        <div>
          <label class="monarch-label monarch-label--error">Company (required)</label>
          <input class="monarch-input monarch-input--error" placeholder="Required field..." />
          <p class="monarch-helper monarch-helper--error">This field is required</p>
        </div>
        <div>
          <label class="monarch-label" style="color: var(--monarch-text-muted);">Disabled</label>
          <input class="monarch-input" value="Cannot edit" disabled />
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Search Input</h2>

    <ComponentPreview title="Search" code='<div class="monarch-search">
  <svg class="monarch-search__icon">...</svg>
  <input class="monarch-search__input" placeholder="Search..." />
  <kbd class="monarch-search__kbd">⌘K</kbd>
</div>'>
      <div class="max-w-md">
        <div class="monarch-search">
          <svg class="monarch-search__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          <input class="monarch-search__input" placeholder="Search accounts, deals, contacts..." />
          <kbd class="monarch-search__kbd">⌘K</kbd>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Select</h2>

    <ComponentPreview title="Select Input" code='<select class="monarch-select">
  <option>All Segments</option>
</select>'>
      <div class="max-w-md">
        <label class="monarch-label">Account Segment</label>
        <select class="monarch-select">
          <option>All Segments</option>
          <option>Fabricator / Installer</option>
          <option>Commercial</option>
          <option>Retailer</option>
          <option>Designer</option>
          <option>Builder</option>
        </select>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Textarea</h2>

    <ComponentPreview title="Textarea" code='<textarea class="monarch-textarea" rows="4" placeholder="Notes..."></textarea>'>
      <div class="max-w-md">
        <label class="monarch-label">Deal Notes</label>
        <textarea class="monarch-textarea" rows="4" placeholder="Add notes about this deal..."></textarea>
        <p class="monarch-helper">Markdown supported</p>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Input with Prefix</h2>

    <ComponentPreview title="Decorated Input" code='<div class="monarch-input-group">
  <span class="monarch-input-group__prefix">$</span>
  <input class="monarch-input" placeholder="0.00" />
</div>'>
      <div class="max-w-md">
        <label class="monarch-label">Deal Value</label>
        <div class="monarch-input-group">
          <span class="monarch-input-group__prefix">$</span>
          <input class="monarch-input" placeholder="0.00" />
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Usage Guidelines</h2>
    <div class="space-y-3" style="color: var(--monarch-text-secondary);">
      <p>• Always include a visible <strong>label</strong> above the input</p>
      <p>• Focus ring is <strong>indigo with 20% opacity</strong> — consistent brand reinforcement</p>
      <p>• Error states use <strong>red border + helper text</strong> below the field</p>
      <p>• <strong>⌘K</strong> shortcut badge on search inputs signals keyboard-first design</p>
      <p>• Disabled inputs use <strong>60% opacity</strong> with base background</p>
    </div>
  </section>
</DocsLayout>
