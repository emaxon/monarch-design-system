---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Badges" description="Status indicators, category labels, and notification markers.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Color Variants</h2>

    <ComponentPreview title="Filled Badges" code='<span class="monarch-badge monarch-badge-success">Active</span>
<span class="monarch-badge monarch-badge-info">Recruiting</span>
<span class="monarch-badge monarch-badge-purple">Review</span>
<span class="monarch-badge monarch-badge-warning">Pending</span>
<span class="monarch-badge monarch-badge-danger">At Risk</span>
<span class="monarch-badge monarch-badge-pink">Marketing</span>'>
      <div class="flex flex-wrap items-center gap-3">
        <span class="monarch-badge monarch-badge-success">Active</span>
        <span class="monarch-badge monarch-badge-info">Recruiting</span>
        <span class="monarch-badge monarch-badge-purple">Review</span>
        <span class="monarch-badge monarch-badge-warning">Pending</span>
        <span class="monarch-badge monarch-badge-danger">At Risk</span>
        <span class="monarch-badge monarch-badge-pink">Marketing</span>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">With Dot Indicator</h2>

    <ComponentPreview title="Dot Badges" code='<span class="monarch-badge monarch-badge-success">
  <span class="monarch-badge__dot monarch-badge__dot--pulse"></span> Online
</span>'>
      <div class="flex flex-wrap items-center gap-3">
        <span class="monarch-badge monarch-badge-success">
          <span class="monarch-badge__dot monarch-badge__dot--pulse"></span> Online
        </span>
        <span class="monarch-badge monarch-badge-warning">
          <span class="monarch-badge__dot"></span> Away
        </span>
        <span class="monarch-badge monarch-badge-neutral">
          <span class="monarch-badge__dot"></span> Offline
        </span>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Outlined</h2>

    <ComponentPreview title="Outlined Badges" code='<span class="monarch-badge monarch-badge-success monarch-badge-outlined">Prospecting</span>'>
      <div class="flex flex-wrap items-center gap-3">
        <span class="monarch-badge monarch-badge-success monarch-badge-outlined">Prospecting</span>
        <span class="monarch-badge monarch-badge-info monarch-badge-outlined">Qualification</span>
        <span class="monarch-badge monarch-badge-purple monarch-badge-outlined">Proposal</span>
        <span class="monarch-badge monarch-badge-warning monarch-badge-outlined">Negotiation</span>
        <span class="monarch-badge monarch-badge-danger monarch-badge-outlined">Closed Lost</span>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Sizes</h2>

    <ComponentPreview title="Badge Sizes" code='<span class="monarch-badge monarch-badge-purple monarch-badge-sm">Small</span>
<span class="monarch-badge monarch-badge-purple">Default</span>
<span class="monarch-badge monarch-badge-purple monarch-badge-lg">Large</span>'>
      <div class="flex flex-wrap items-center gap-3">
        <span class="monarch-badge monarch-badge-purple monarch-badge-sm">Small</span>
        <span class="monarch-badge monarch-badge-purple">Default</span>
        <span class="monarch-badge monarch-badge-purple monarch-badge-lg">Large</span>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Notification Counter</h2>

    <ComponentPreview title="Count Badges" code='<span class="monarch-badge-count">3</span>
<span class="monarch-badge-count monarch-badge-count-purple">12</span>'>
      <div class="flex items-center gap-6">
        <div class="relative">
          <svg class="w-6 h-6" style="color: var(--monarch-text-secondary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
          <span class="monarch-badge-count" style="position: absolute; top: -6px; right: -6px;">3</span>
        </div>
        <div class="relative">
          <svg class="w-6 h-6" style="color: var(--monarch-text-secondary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          <span class="monarch-badge-count monarch-badge-count-purple" style="position: absolute; top: -6px; right: -8px;">12</span>
        </div>
        <div class="relative">
          <svg class="w-6 h-6" style="color: var(--monarch-text-secondary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          <span class="monarch-badge-count monarch-badge-count-success" style="position: absolute; top: -6px; right: -10px;">99+</span>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Usage Guidelines</h2>
    <div class="space-y-3" style="color: var(--monarch-text-secondary);">
      <p>• <strong>Green</strong> → Active, Online, Success, Healthy, Prospecting</p>
      <p>• <strong>Blue</strong> → Info, Recruiting, In Progress, Qualification</p>
      <p>• <strong>Indigo</strong> → Review, Featured, Proposal, Brand-related</p>
      <p>• <strong>Amber</strong> → Warning, Pending, Away, Negotiation</p>
      <p>• <strong>Red</strong> → Alert, At Risk, Error, Closed Lost</p>
      <p>• <strong>Violet</strong> → Marketing, Social, Engagement</p>
      <p>• Use <strong>filled badges</strong> in tables and lists for high visibility</p>
      <p>• Use <strong>outlined badges</strong> for pipeline stages and categories</p>
      <p>• Use <strong>dot indicators</strong> for real-time status (online/away/offline)</p>
    </div>
  </section>
</DocsLayout>
