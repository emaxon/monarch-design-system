---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Stat Cards" description="KPI and metric display cards — the dashboard's heartbeat.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Standard Stats</h2>
    <p class="text-[var(--monarch-text-secondary)] mb-6">Extracted from the Monarch dashboard — icon, large number, and label. The grid of these creates the KPI overview bar.</p>

    <ComponentPreview title="Stat Card Row">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="monarch-card p-4 flex flex-col gap-2">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[rgba(59,130,246,0.12)]">
            <svg class="w-4 h-4 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          </div>
          <span class="text-2xl font-bold">433</span>
          <span class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Total Accounts</span>
        </div>
        <div class="monarch-card p-4 flex flex-col gap-2">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[rgba(34,197,94,0.12)]">
            <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <span class="text-2xl font-bold">$144.8M</span>
          <span class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Pipeline Value</span>
        </div>
        <div class="monarch-card p-4 flex flex-col gap-2">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[rgba(124,58,237,0.12)]">
            <svg class="w-4 h-4 text-[#A855F7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
          </div>
          <span class="text-2xl font-bold">81</span>
          <span class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Avg Health</span>
        </div>
        <div class="monarch-card p-4 flex flex-col gap-2">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[rgba(236,72,153,0.12)]">
            <svg class="w-4 h-4 text-[#EC4899]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <span class="text-2xl font-bold">20</span>
          <span class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Active Agents</span>
        </div>
        <div class="monarch-card p-4 flex flex-col gap-2">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[rgba(245,158,11,0.12)]">
            <svg class="w-4 h-4 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
          </div>
          <span class="text-2xl font-bold">$3.01M</span>
          <span class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Inference Tax Saved</span>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">With Trend</h2>

    <ComponentPreview title="Stat Cards with Trends">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="monarch-card p-5">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Revenue</span>
            <span class="text-xs font-semibold text-[#22C55E] flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12" /></svg>
              12.5%
            </span>
          </div>
          <span class="text-3xl font-bold">$2.4M</span>
          <p class="text-xs text-[var(--monarch-text-muted)] mt-1">vs $2.1M last quarter</p>
        </div>
        <div class="monarch-card p-5">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Win Rate</span>
            <span class="text-xs font-semibold text-[#EF4444] flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6" /></svg>
              3.2%
            </span>
          </div>
          <span class="text-3xl font-bold">34%</span>
          <p class="text-xs text-[var(--monarch-text-muted)] mt-1">vs 37% last quarter</p>
        </div>
        <div class="monarch-card p-5">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Avg Deal Size</span>
            <span class="text-xs font-semibold text-[var(--monarch-text-muted)] flex items-center gap-1">—</span>
          </div>
          <span class="text-3xl font-bold">$185K</span>
          <p class="text-xs text-[var(--monarch-text-muted)] mt-1">No change from last quarter</p>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Usage Guidelines</h2>
    <div class="space-y-3 text-[var(--monarch-text-secondary)]">
      <p>• Stat cards work best in a <strong>horizontal row</strong> — 3-5 cards across</p>
      <p>• Icon color should match the metric's <strong>semantic category</strong></p>
      <p>• Numbers should be <strong>formatted for readability</strong> — $144.8M not $144,825,520</p>
      <p>• Labels are <strong>uppercase, widest tracking, xs size</strong> — subtle but scannable</p>
      <p>• Trend indicators: <strong>green up arrow</strong> = good, <strong>red down arrow</strong> = concern, <strong>dash</strong> = flat</p>
    </div>
  </section>
</DocsLayout>
