---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Search Bar" description="The command-palette-style search — fast access to everything in Monarch.">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Default Search</h2>

    <ComponentPreview title="Search Bar" code='<div class="monarch-search">
  <svg class="monarch-search__icon">...</svg>
  <input class="monarch-search__input" placeholder="Search or type a command..." />
  <kbd class="monarch-search__kbd">⌘K</kbd>
</div>'>
      <div style="max-width: 32rem;">
        <div class="monarch-search">
          <svg class="monarch-search__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          <input class="monarch-search__input" placeholder="Search or type a command..." />
          <kbd class="monarch-search__kbd">⌘K</kbd>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Active Search with Results</h2>

    <ComponentPreview title="Search with Results" code='<div class="monarch-command-palette">
  <div class="monarch-command-palette__input">...</div>
  <div class="monarch-command-palette__results">
    <div class="monarch-command-palette__group-title">Accounts</div>
    <button class="monarch-command-palette__item monarch-command-palette__item--selected">...</button>
  </div>
</div>'>
      <div style="max-width: 32rem;">
        <div class="monarch-command-palette">
          <div class="monarch-command-palette__input">
            <svg class="monarch-command-palette__input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            <span style="flex: 1; font-size: var(--monarch-text-sm); color: var(--monarch-text-primary);">Baltix</span>
            <kbd class="monarch-command-palette__item-kbd">ESC</kbd>
          </div>

          <div class="monarch-command-palette__results">
            <div class="monarch-command-palette__group-title">Accounts</div>
            <div class="monarch-command-palette__item monarch-command-palette__item--selected" style="text-decoration: none;">
              <svg class="monarch-command-palette__item-icon" style="color: var(--monarch-brand-purple);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
              <div class="monarch-command-palette__item-label">
                <div><mark style="background: rgba(99,102,241,0.2); color: var(--monarch-text-primary); border-radius: 2px; padding: 0 2px;">Baltix</mark> Construction</div>
                <div style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">Fabricator · Minneapolis, MN</div>
              </div>
              <span style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">↵</span>
            </div>
            <div class="monarch-command-palette__item" style="text-decoration: none;">
              <svg class="monarch-command-palette__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
              <div class="monarch-command-palette__item-label">
                <div><mark style="background: rgba(99,102,241,0.2); color: var(--monarch-text-primary); border-radius: 2px; padding: 0 2px;">Baltix</mark> Home Designs</div>
                <div style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">Designer · Chicago, IL</div>
              </div>
            </div>

            <div class="monarch-command-palette__group-title" style="margin-top: 8px;">Deals</div>
            <div class="monarch-command-palette__item" style="text-decoration: none;">
              <svg class="monarch-command-palette__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <div class="monarch-command-palette__item-label">
                <div>Renovation - <mark style="background: rgba(99,102,241,0.2); color: var(--monarch-text-primary); border-radius: 2px; padding: 0 2px;">Baltix</mark></div>
                <div style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">$154,527 · Prospecting</div>
              </div>
            </div>
          </div>

          <div class="monarch-command-palette__footer">
            <span class="monarch-command-palette__footer-shortcut"><kbd class="monarch-command-palette__item-kbd">↑↓</kbd> Navigate</span>
            <span class="monarch-command-palette__footer-shortcut"><kbd class="monarch-command-palette__item-kbd">↵</kbd> Open</span>
            <span class="monarch-command-palette__footer-shortcut"><kbd class="monarch-command-palette__item-kbd">ESC</kbd> Close</span>
          </div>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Usage Guidelines</h2>
    <div class="space-y-3" style="color: var(--monarch-text-secondary);">
      <p>• The search bar doubles as a <strong>command palette trigger</strong> — keyboard-first design</p>
      <p>• Results are grouped by <strong>entity type</strong> (Accounts, Deals, Contacts, Actions)</p>
      <p>• Matching text is highlighted with <strong>indigo background</strong></p>
      <p>• First result is <strong>auto-selected</strong> — Enter opens it immediately</p>
      <p>• Keyboard shortcuts in the footer reinforce the <strong>power-user experience</strong></p>
    </div>
  </section>
</DocsLayout>
