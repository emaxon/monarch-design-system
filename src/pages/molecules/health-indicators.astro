---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Health Indicators" description="Visual health scores for accounts and deals — at a glance, how are things going?">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Circular Progress Ring</h2>

    <ComponentPreview title="Health Scores">
      <div class="flex items-center gap-8">
        <!-- Healthy (81) -->
        <div class="flex flex-col items-center gap-2">
          <div class="relative w-16 h-16">
            <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="var(--monarch-border-subtle)" stroke-width="3" />
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#22C55E" stroke-width="3" stroke-dasharray="81, 100" stroke-linecap="round" />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center text-sm font-bold text-[#22C55E]">81</span>
          </div>
          <span class="text-xs text-[var(--monarch-text-muted)]">Healthy</span>
        </div>

        <!-- Warning (52) -->
        <div class="flex flex-col items-center gap-2">
          <div class="relative w-16 h-16">
            <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="var(--monarch-border-subtle)" stroke-width="3" />
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#F59E0B" stroke-width="3" stroke-dasharray="52, 100" stroke-linecap="round" />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center text-sm font-bold text-[#F59E0B]">52</span>
          </div>
          <span class="text-xs text-[var(--monarch-text-muted)]">At Risk</span>
        </div>

        <!-- Critical (25) -->
        <div class="flex flex-col items-center gap-2">
          <div class="relative w-16 h-16">
            <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="var(--monarch-border-subtle)" stroke-width="3" />
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#EF4444" stroke-width="3" stroke-dasharray="25, 100" stroke-linecap="round" />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center text-sm font-bold text-[#EF4444]">25</span>
          </div>
          <span class="text-xs text-[var(--monarch-text-muted)]">Critical</span>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Compact Inline</h2>

    <ComponentPreview title="Inline Health Scores">
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <div class="relative w-8 h-8">
            <svg class="w-8 h-8 -rotate-90" viewBox="0 0 36 36">
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="var(--monarch-border-subtle)" stroke-width="4" />
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#22C55E" stroke-width="4" stroke-dasharray="92, 100" stroke-linecap="round" />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-[#22C55E]">92</span>
          </div>
          <span class="text-sm text-[var(--monarch-text-primary)]">The Kitchen Source - Dallas</span>
          <span class="text-xs text-[var(--monarch-text-muted)]">$2.4M pipeline</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="relative w-8 h-8">
            <svg class="w-8 h-8 -rotate-90" viewBox="0 0 36 36">
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="var(--monarch-border-subtle)" stroke-width="4" />
              <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#EF4444" stroke-width="4" stroke-dasharray="25, 100" stroke-linecap="round" />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-[#EF4444]">25</span>
          </div>
          <span class="text-sm text-[var(--monarch-text-primary)]">Baltix Construction</span>
          <span class="text-xs text-[var(--monarch-text-muted)]">$154K pipeline</span>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Color Thresholds</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead><tr class="border-b border-[var(--monarch-border-subtle)]">
          <th class="text-left py-3 pr-4 text-[var(--monarch-text-muted)] font-medium">Score Range</th>
          <th class="text-left py-3 pr-4 text-[var(--monarch-text-muted)] font-medium">Color</th>
          <th class="text-left py-3 text-[var(--monarch-text-muted)] font-medium">Status</th>
        </tr></thead>
        <tbody class="text-[var(--monarch-text-secondary)]">
          <tr class="border-b border-[var(--monarch-border-subtle)]"><td class="py-3 pr-4">70–100</td><td class="py-3 pr-4"><span class="text-[#22C55E] font-semibold">Green</span></td><td class="py-3">Healthy</td></tr>
          <tr class="border-b border-[var(--monarch-border-subtle)]"><td class="py-3 pr-4">40–69</td><td class="py-3 pr-4"><span class="text-[#F59E0B] font-semibold">Amber</span></td><td class="py-3">At Risk</td></tr>
          <tr><td class="py-3 pr-4">0–39</td><td class="py-3 pr-4"><span class="text-[#EF4444] font-semibold">Red</span></td><td class="py-3">Critical</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</DocsLayout>
