---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentPreview from '../../components/ComponentPreview.astro';
---

<DocsLayout title="Health Indicators" description="Visual health scores for accounts and deals — at a glance, how are things going?">

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Circular Progress Ring</h2>

    <ComponentPreview title="Health Scores" code='<div class="monarch-health-ring monarch-health-ring-lg">
  <svg class="monarch-health-ring__svg" viewBox="0 0 36 36">
    <path class="monarch-health-ring__track" d="M18 2.08..." stroke-width="3" />
    <path class="monarch-health-ring__fill monarch-health-ring__fill--healthy" stroke-width="3" stroke-dasharray="81, 100" />
  </svg>
  <span class="monarch-health-ring__value" style="color: #22C55E;">81</span>
</div>'>
      <div class="flex items-center gap-8">
        <div class="flex flex-col items-center gap-2">
          <div class="monarch-health-ring monarch-health-ring-lg">
            <svg class="monarch-health-ring__svg" viewBox="0 0 36 36">
              <path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="3" />
              <path class="monarch-health-ring__fill monarch-health-ring__fill--healthy" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="3" stroke-dasharray="81, 100" />
            </svg>
            <span class="monarch-health-ring__value" style="color: #22C55E;">81</span>
          </div>
          <span style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">Healthy</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="monarch-health-ring monarch-health-ring-lg">
            <svg class="monarch-health-ring__svg" viewBox="0 0 36 36">
              <path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="3" />
              <path class="monarch-health-ring__fill monarch-health-ring__fill--warning" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="3" stroke-dasharray="52, 100" />
            </svg>
            <span class="monarch-health-ring__value" style="color: #F59E0B;">52</span>
          </div>
          <span style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">At Risk</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="monarch-health-ring monarch-health-ring-lg">
            <svg class="monarch-health-ring__svg" viewBox="0 0 36 36">
              <path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="3" />
              <path class="monarch-health-ring__fill monarch-health-ring__fill--critical" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="3" stroke-dasharray="25, 100" />
            </svg>
            <span class="monarch-health-ring__value" style="color: #EF4444;">25</span>
          </div>
          <span style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">Critical</span>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Compact Inline</h2>

    <ComponentPreview title="Inline Health Scores" code='<div class="monarch-health-ring monarch-health-ring-sm">...</div>'>
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <div class="monarch-health-ring monarch-health-ring-sm">
            <svg class="monarch-health-ring__svg" viewBox="0 0 36 36">
              <path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" />
              <path class="monarch-health-ring__fill monarch-health-ring__fill--healthy" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="92, 100" />
            </svg>
            <span class="monarch-health-ring__value" style="color: #22C55E;">92</span>
          </div>
          <span style="font-size: var(--monarch-text-sm);">The Kitchen Source - Dallas</span>
          <span style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">$2.4M pipeline</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="monarch-health-ring monarch-health-ring-sm">
            <svg class="monarch-health-ring__svg" viewBox="0 0 36 36">
              <path class="monarch-health-ring__track" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" />
              <path class="monarch-health-ring__fill monarch-health-ring__fill--critical" d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831a 15.9155 15.9155 0 0 1 0 -31.831" stroke-width="4" stroke-dasharray="25, 100" />
            </svg>
            <span class="monarch-health-ring__value" style="color: #EF4444;">25</span>
          </div>
          <span style="font-size: var(--monarch-text-sm);">Baltix Construction</span>
          <span style="font-size: var(--monarch-text-xs); color: var(--monarch-text-muted);">$154K pipeline</span>
        </div>
      </div>
    </ComponentPreview>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Color Thresholds</h2>
    <table class="monarch-table">
      <thead><tr><th>Score Range</th><th>Color</th><th>Status</th></tr></thead>
      <tbody>
        <tr><td>70–100</td><td><span style="color: #22C55E; font-weight: 600;">Green</span></td><td>Healthy</td></tr>
        <tr><td>40–69</td><td><span style="color: #F59E0B; font-weight: 600;">Amber</span></td><td>At Risk</td></tr>
        <tr><td>0–39</td><td><span style="color: #EF4444; font-weight: 600;">Red</span></td><td>Critical</td></tr>
      </tbody>
    </table>
  </section>
</DocsLayout>
