---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Monarch Design System</title>
    <meta name="description" content="A premium design system built on Atomic Design principles. Dark-first, purposeful, beautiful." />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Instrument+Serif:ital@1&display=swap" rel="stylesheet" />
    <style is:global>
      @import '../styles/global.css';
    </style>
    <style>
      #site-nav {
        background: rgba(20, 20, 30, 0.55);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        transition: background-color 300ms ease;
      }

      [data-theme="light"] #site-nav {
        background: rgba(247, 245, 243, 0.60);
      }

      [data-theme="light"] #site-nav.is-docked {
        background: var(--monarch-bg-surface);
      }

    </style>
    <script is:inline>
      const theme = localStorage.getItem('monarch-theme') || 'dark';
      if (theme === 'light') document.documentElement.setAttribute('data-theme', 'light');
    </script>
  </head>
  <body class="min-h-screen bg-[var(--monarch-bg-base)] text-[var(--monarch-text-primary)] overflow-x-hidden">
    <div class="noise-overlay"></div>

    <nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-10 py-4 border-b border-[var(--monarch-border-subtle)]">
      <a href={`${base}/`} class="flex items-center gap-2.5">
        <div class="shrink-0 flex items-center justify-center" style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #7C55F5 0%, #AB76E2 100%);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F7F5F3" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" />
            <path d="M5 21h14" />
          </svg>
        </div>
        <svg class="h-[17px] w-auto" viewBox="0 0 171 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Monarch"><title>Monarch</title>
          <path d="M0.716916 0.342857H5.93363L13.0875 20.5143L20.2414 0.342857H25.3056V0.895238C24.4921 1.2127 24.1158 2.85079 24.1769 5.80952L24.6497 22.1905C24.7311 25.1619 25.1887 26.7873 26.0225 27.0667V27.6571H20.1499V27.0667C20.9838 26.7746 21.36 25.1492 21.2787 22.1905L20.7753 4.68571L13.5909 25.8286L11.4707 26.019L4.22523 4.68571L3.75237 21.6952C3.66085 24.9841 4.02693 26.7746 4.85062 27.0667V27.6571H0V27.0667C0.823691 26.7746 1.2813 24.9841 1.37282 21.6952L1.81517 5.80952C1.89652 2.86349 1.53044 1.2254 0.716916 0.895238V0.342857Z" fill="currentColor"/>
          <path d="M30.7725 14C30.7725 9.73333 31.6724 6.33651 33.4724 3.80952C35.2723 1.26984 37.6722 0 40.672 0C43.6719 0 46.0667 1.26984 47.8564 3.80952C49.6462 6.33651 50.5411 9.73333 50.5411 14C50.5411 18.254 49.6462 21.6508 47.8564 24.1905C46.0667 26.7302 43.6719 28 40.672 28C37.6722 28 35.2723 26.7302 33.4724 24.1905C31.6724 21.6381 30.7725 18.2413 30.7725 14ZM36.0807 5.52381C34.952 7.61905 34.3876 10.4444 34.3876 14C34.3876 17.5556 34.952 20.3873 36.0807 22.4952C37.2196 24.5905 38.7501 25.6381 40.672 25.6381C42.5838 25.6381 44.1041 24.5905 45.2328 22.4952C46.3616 20.3873 46.926 17.5556 46.926 14C46.926 10.4444 46.3616 7.61905 45.2328 5.52381C44.1041 3.42857 42.5838 2.38095 40.672 2.38095C38.7501 2.38095 37.2196 3.42857 36.0807 5.52381Z" fill="currentColor"/>
          <path d="M55.7639 0.895238V0.342857H60.3857L71.7801 20.019V6.32381C71.7801 3.02222 71.3682 1.2127 70.5446 0.895238V0.342857H75.4409V0.895238C74.6071 1.2254 74.1901 3.03492 74.1901 6.32381V27.7333H72.1309L59.4095 5.84762V21.6952C59.4095 24.9841 59.8264 26.7746 60.6603 27.0667V27.6571H55.7639V27.0667C56.5977 26.7746 57.0147 24.9841 57.0147 21.6952V5.80952C57.0147 2.86349 56.5977 1.2254 55.7639 0.895238Z" fill="currentColor"/>
          <path d="M84.4771 27.6571H79.2604V27.0667C80.1858 26.6857 81.1417 24.9841 82.1281 21.9619L89.282 0.419048L91.6615 0.190476L98.9985 22.1905C99.9646 25.1492 100.915 26.7746 101.851 27.0667V27.6571H95.3834V27.0667C96.2986 26.7746 96.4003 25.5175 95.6885 23.2952L94.5292 19.7333H85.3161L84.2178 23.0476C83.4755 25.3587 83.5619 26.6984 84.4771 27.0667V27.6571ZM89.9074 5.42857L86.033 17.3143H93.8123L89.9074 5.42857Z" fill="currentColor"/>
          <path d="M110.521 15.8857V22.1905C110.521 25.1492 110.938 26.7746 111.772 27.0667V27.6571H105.808V27.0667C106.642 26.7746 107.058 25.1492 107.058 22.1905V5.80952C107.058 2.86349 106.642 1.2254 105.808 0.895238V0.342857H114.578C116.928 0.342857 118.804 1.04762 120.207 2.45714C121.621 3.86667 122.327 5.75238 122.327 8.11429C122.327 9.81587 121.956 11.2825 121.214 12.5143C120.471 13.746 119.429 14.6476 118.087 15.219C119.073 15.9302 119.749 16.8254 120.115 17.9048L121.549 22.1905C122.526 25.1492 123.431 26.7746 124.264 27.0667V27.6571H119.856L119.46 27.1429L116.714 18.4571C116.46 17.6571 116.063 17.0286 115.524 16.5714C114.985 16.1143 114.38 15.8857 113.709 15.8857H110.521ZM114.578 2.7619H110.521V13.4667H114.578C115.839 13.4667 116.841 12.9841 117.583 12.019C118.336 11.054 118.712 9.75238 118.712 8.11429C118.712 6.48889 118.336 5.19365 117.583 4.22857C116.841 3.25079 115.839 2.7619 114.578 2.7619Z" fill="currentColor"/>
          <path d="M138.365 0C140.999 0 143.256 0.768254 145.137 2.30476L144.634 6.51429C142.407 3.80952 140.221 2.45714 138.075 2.45714C136.031 2.45714 134.44 3.38413 133.301 5.23809C132.172 7.07936 131.608 9.66349 131.608 12.9905C131.608 16.7873 132.289 19.7397 133.651 21.8476C135.014 23.9556 136.906 25.0095 139.326 25.0095C140.383 25.0095 141.39 24.819 142.346 24.4381C143.302 24.0444 144.131 23.5048 144.832 22.819L145.259 25.0476C143.236 27.0159 140.821 28 138.014 28C134.872 28 132.421 26.781 130.662 24.3429C128.903 21.9048 128.023 18.4952 128.023 14.1143C128.023 9.64444 128.933 6.17778 130.753 3.71429C132.584 1.2381 135.121 0 138.365 0Z" fill="currentColor"/>
          <path d="M150.33 0.895238V0.342857H156.294V0.895238C155.46 1.2254 155.043 2.86349 155.043 5.80952V12.5905H165.69V5.80952C165.69 2.85079 165.278 1.2127 164.454 0.895238V0.342857H170.419V0.895238C169.585 1.2254 169.168 2.86349 169.168 5.80952V22.1905C169.168 25.1492 169.585 26.7746 170.419 27.0667V27.6571H164.454V27.0667C165.278 26.7873 165.69 25.1619 165.69 22.1905V15.0095H155.043V22.1905C155.043 25.1492 155.46 26.7746 156.294 27.0667V27.6571H150.33V27.0667C151.164 26.7746 151.58 25.1492 151.58 22.1905V5.80952C151.58 2.86349 151.164 1.2254 150.33 0.895238Z" fill="currentColor"/>
        </svg>
      </a>
      <div class="flex items-center gap-6">
        <a href={`${base}/getting-started`} class="text-sm text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] transition-colors duration-200">Docs</a>
        <a href="https://github.com/emaxon/monarch-design-system" target="_blank" rel="noopener" class="text-sm text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] transition-colors duration-200">GitHub</a>
      </div>
    </nav>

    <div class="monarch-blueprint">

      <!-- Hero -->
      <section class="monarch-hero-grid relative min-h-screen flex items-center justify-center px-6 pt-24 pb-24">
        <!-- Background gradient orbs -->
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#7C55F5] rounded-full opacity-10 blur-[128px] pointer-events-none animate-fade-in"></div>
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-[#E0B2B3] rounded-full opacity-8 blur-[128px] pointer-events-none animate-fade-in delay-2"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#AB76E2] rounded-full opacity-5 blur-[200px] pointer-events-none"></div>

        <div class="relative z-10 text-center max-w-4xl mx-auto">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--monarch-border-subtle)] bg-[var(--monarch-bg-surface)] mb-8 animate-fade-in-up">
            <span class="w-2 h-2 rounded-full bg-[var(--monarch-success)] animate-[monarch-pulse-dot_2s_ease-in-out_infinite]"></span>
            <span class="text-sm text-[var(--monarch-text-secondary)]">v1.0 — Atomic Design System</span>
          </div>

          <!-- Heading -->
          <h1 class="relative inline-block text-5xl md:text-7xl leading-none tracking-tight mb-6 animate-fade-in-up delay-1">
            Design with <em class="monarch-gradient-text">intention.</em><svg xmlns="http://www.w3.org/2000/svg" width="51" height="52" fill="none" style="position: absolute;top: -2px;right: -8px;color: #9d7dff;"><path fill="currentColor" d="M51 52h-4v-4h4zm-4-4h-4v-4h4zm-4-4h-4v-4h4zm-4-4h-4v-4h4zm12-16v4H35v-4zm-35-8h-4v-4h4zm12 0h-4V0h4zm11 0h-4v-4h4zm-27-4H8V8h4zm31 0h-4V8h4zM8 8H4V4h4zm39 0h-4V4h4zM4 4H0V0h4zm47 0h-4V0h4z"></path></svg>
          </h1>

          <!-- Subtitle -->
          <p class="md:text-lg text-[var(--monarch-text-secondary)] max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-in-up delay-2">
            A premium design system built on Atomic Design principles.
            Dark-first. Purposeful. Every component crafted to make your product feel like it was built by people who care.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up delay-3">
            <a href={`${base}/getting-started`} class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg font-semibold text-white transition-all duration-300 hover:shadow-[var(--monarch-glow-purple)] hover:scale-[1.02]" style="background: var(--monarch-brand-violet);">
              Get Started
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href={`${base}/tokens/colors`} class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg font-semibold border border-[var(--monarch-border-medium)] text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] hover:border-[var(--monarch-border-strong)] transition-all duration-200">
              Browse Components
            </a>
          </div>
        </div>
      </section>

      <!-- Rule: hero → feature cards -->
      <div class="monarch-blueprint-rule"></div>

      <!-- Feature Cards -->
      <section class="relative py-24">
        <div class="max-w-6xl mx-auto px-8 grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Card 1 -->
          <div class="monarch-card p-8 animate-fade-in-up delay-1">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: var(--monarch-brand-gradient-subtle);">
              <svg class="w-6 h-6 text-[var(--monarch-brand-violet)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Atomic Architecture</h3>
            <p class="text-[var(--monarch-text-secondary)] leading-relaxed">Atoms → Molecules → Organisms → Templates. Every component is composable, predictable, and purpose-built.</p>
          </div>

          <!-- Card 2 -->
          <div class="monarch-card p-8 animate-fade-in-up delay-2">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: rgba(224, 178, 179, 0.12);">
              <svg class="w-6 h-6 text-[#E0B2B3]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Dark-First</h3>
            <p class="text-[var(--monarch-text-secondary)] leading-relaxed">Designed in the dark, perfected in the light. Full theme support with CSS custom properties and seamless transitions.</p>
          </div>

          <!-- Card 3 -->
          <div class="monarch-card p-8 animate-fade-in-up delay-3">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: var(--monarch-info-dim);">
              <svg class="w-6 h-6 text-[var(--monarch-info)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Tailwind Native</h3>
            <p class="text-[var(--monarch-text-secondary)] leading-relaxed">Ships as a Tailwind preset and standalone CSS tokens. Import into any project — framework-agnostic by design.</p>
          </div>
        </div>
      </section>

      <!-- Rule: feature cards → preview -->
      <div class="monarch-blueprint-rule"></div>

      <!-- Preview Section -->
      <section class="relative py-24">
        <div class="max-w-6xl mx-auto px-8">
          <h2 class="text-4xl md:text-5xl monarch-display text-center mb-4">Built for <em class="monarch-gradient-text">real products.</em></h2>
          <p class="text-center text-[var(--monarch-text-secondary)] mb-16 max-w-2xl mx-auto">Every component is extracted from real Monarch interfaces — dashboards, data tables, agent feeds, and conversational AI.</p>

          <!-- Component Preview Grid -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <!-- Buttons preview -->
            <div class="monarch-card p-6 flex flex-col items-center gap-3">
              <button class="w-full px-4 py-2 rounded-lg text-sm font-semibold text-white" style="background: var(--monarch-brand-violet);">Primary</button>
              <button class="w-full px-4 py-2 rounded-lg text-sm font-semibold border border-[var(--monarch-brand-violet)] text-[var(--monarch-brand-violet)]">Secondary</button>
              <span class="text-xs text-[var(--monarch-text-muted)] mt-1">Buttons</span>
            </div>

            <!-- Badges preview -->
            <div class="monarch-card p-6 flex flex-col items-center gap-3">
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-[var(--monarch-success-dim)] text-[var(--monarch-success)]">Active</span>
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-[var(--monarch-danger-dim)] text-[var(--monarch-danger)]">Alert</span>
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-[rgba(124,85,245,0.15)] text-[#AB76E2]">Info</span>
              <span class="text-xs text-[var(--monarch-text-muted)] mt-1">Badges</span>
            </div>

            <!-- Avatar preview -->
            <div class="monarch-card p-6 flex flex-col items-center gap-3">
              <div class="flex -space-x-2">
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold bg-[var(--monarch-info)] text-white border-2 border-[var(--monarch-bg-surface)]">EM</div>
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold bg-[var(--monarch-success)] text-white border-2 border-[var(--monarch-bg-surface)]">KM</div>
              </div>
              <span class="text-xs text-[var(--monarch-text-muted)] mt-1">Avatars</span>
            </div>

            <!-- Card preview -->
            <div class="monarch-card p-6 flex flex-col items-center gap-3">
              <div class="w-full p-3 rounded-lg bg-[var(--monarch-bg-elevated)] border border-[var(--monarch-border-subtle)]">
                <div class="text-2xl font-bold">433</div>
                <div class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Accounts</div>
              </div>
              <span class="text-xs text-[var(--monarch-text-muted)] mt-1">Stat Cards</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Rule: preview → footer -->
      <div class="monarch-blueprint-rule"></div>

      <!-- Footer -->
      <footer class="py-8">
        <div class="max-w-6xl mx-auto px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2 text-sm text-[var(--monarch-text-muted)]">
            <div class="shrink-0 flex items-center justify-center" style="width: 20px; height: 20px; border-radius: 5px; background: linear-gradient(135deg, #7C55F5 0%, #AB76E2 100%);">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#F7F5F3" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" /><path d="M5 21h14" /></svg>
            </div>
            <span>Monarch Design System</span>
          </div>
          <div class="flex items-center gap-6 text-sm text-[var(--monarch-text-muted)]">
            <a href="https://github.com/emaxon/monarch-design-system" target="_blank" rel="noopener" class="hover:text-[var(--monarch-text-primary)] transition-colors duration-200">GitHub</a>
            <span>Built with Astro + Tailwind</span>
          </div>
        </div>
      </footer>

    </div>

    <script>
      const nav = document.getElementById('site-nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('is-docked', window.scrollY > 16);
      }, { passive: true });
    </script>
  </body>
</html>
