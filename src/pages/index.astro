---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Monarch Design System</title>
    <meta name="description" content="A premium design system built on Atomic Design principles. Dark-first, purposeful, beautiful." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      @import '../styles/global.css';
    </style>
    <script is:inline>
      const theme = localStorage.getItem('monarch-theme') || 'dark';
      if (theme === 'light') document.documentElement.setAttribute('data-theme', 'light');
    </script>
  </head>
  <body class="min-h-screen bg-[var(--monarch-bg-base)] text-[var(--monarch-text-primary)] overflow-x-hidden">

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-10 py-4" style="backdrop-filter: var(--monarch-glass-blur); -webkit-backdrop-filter: var(--monarch-glass-blur); background: var(--monarch-bg-overlay);">
      <a href={`${base}/`} class="flex items-center gap-2.5">
        <div class="shrink-0 flex items-center justify-center" style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" />
            <path d="M5 21h14" />
          </svg>
        </div>
        <span class="text-lg font-bold">Monarch</span>
      </a>
      <div class="flex items-center gap-6">
        <a href={`${base}/getting-started`} class="text-sm text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] transition-colors duration-200">Docs</a>
        <a href="https://github.com/emaxon/monarch-design-system" target="_blank" rel="noopener" class="text-sm text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] transition-colors duration-200">GitHub</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative min-h-screen flex items-center justify-center px-6 pt-20 pb-32">
      <!-- Background gradient orbs -->
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#6366f1] rounded-full opacity-10 blur-[128px] pointer-events-none animate-fade-in"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-[#a78bfa] rounded-full opacity-8 blur-[128px] pointer-events-none animate-fade-in delay-2"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#818cf8] rounded-full opacity-5 blur-[200px] pointer-events-none"></div>

      <div class="relative z-10 text-center max-w-4xl mx-auto">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--monarch-border-subtle)] bg-[var(--monarch-bg-surface)] mb-8 animate-fade-in-up">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] animate-[monarch-pulse-dot_2s_ease-in-out_infinite]"></span>
          <span class="text-sm text-[var(--monarch-text-secondary)]">v1.0 — Atomic Design System</span>
        </div>

        <!-- Heading -->
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold leading-none tracking-tight mb-6 animate-fade-in-up delay-1">
          Design with
          <br />
          <span class="monarch-gradient-text">intention.</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-[var(--monarch-text-secondary)] max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-in-up delay-2">
          A premium design system built on Atomic Design principles.
          Dark-first. Purposeful. Every component crafted to make your product feel like it was built by people who care.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up delay-3">
          <a href={`${base}/getting-started`} class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg font-semibold text-white transition-all duration-300 hover:shadow-[var(--monarch-glow-purple)] hover:scale-[1.02]" style="background: var(--monarch-brand-gradient);">
            Get Started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href={`${base}/tokens/colors`} class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg font-semibold border border-[var(--monarch-border-medium)] text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)] hover:border-[var(--monarch-border-strong)] transition-all duration-200">
            Browse Components
          </a>
        </div>
      </div>
    </section>

    <!-- Feature Cards -->
    <section class="relative px-6 md:px-10 pb-32 -mt-16">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="monarch-card p-8 animate-fade-in-up delay-1">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: var(--monarch-brand-gradient-subtle);">
            <svg class="w-6 h-6 text-[var(--monarch-brand-purple)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Atomic Architecture</h3>
          <p class="text-[var(--monarch-text-secondary)] leading-relaxed">Atoms → Molecules → Organisms → Templates. Every component is composable, predictable, and purpose-built.</p>
        </div>

        <!-- Card 2 -->
        <div class="monarch-card p-8 animate-fade-in-up delay-2">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: rgba(167, 139, 250, 0.12);">
            <svg class="w-6 h-6 text-[#a78bfa]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Dark-First</h3>
          <p class="text-[var(--monarch-text-secondary)] leading-relaxed">Designed in the dark, perfected in the light. Full theme support with CSS custom properties and seamless transitions.</p>
        </div>

        <!-- Card 3 -->
        <div class="monarch-card p-8 animate-fade-in-up delay-3">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: rgba(59, 130, 246, 0.12);">
            <svg class="w-6 h-6 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">Tailwind Native</h3>
          <p class="text-[var(--monarch-text-secondary)] leading-relaxed">Ships as a Tailwind preset and standalone CSS tokens. Import into any project — framework-agnostic by design.</p>
        </div>
      </div>
    </section>

    <!-- Preview Section -->
    <section class="relative px-6 md:px-10 pb-32">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Built for <span class="monarch-gradient-text">real products.</span></h2>
        <p class="text-center text-[var(--monarch-text-secondary)] mb-16 max-w-2xl mx-auto">Every component is extracted from real Monarch interfaces — dashboards, data tables, agent feeds, and conversational AI.</p>

        <!-- Component Preview Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <!-- Buttons preview -->
          <div class="monarch-card p-6 flex flex-col items-center gap-3">
            <button class="px-4 py-2 rounded-lg text-sm font-semibold text-white" style="background: var(--monarch-brand-gradient);">Primary</button>
            <button class="px-4 py-2 rounded-lg text-sm font-semibold border border-[var(--monarch-brand-purple)] text-[var(--monarch-brand-purple)]">Secondary</button>
            <span class="text-xs text-[var(--monarch-text-muted)] mt-1">Buttons</span>
          </div>

          <!-- Badges preview -->
          <div class="monarch-card p-6 flex flex-col items-center gap-3">
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-[rgba(34,197,94,0.15)] text-[#22C55E]">Active</span>
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-[rgba(239,68,68,0.15)] text-[#EF4444]">Alert</span>
            <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-[rgba(99,102,241,0.15)] text-[#818cf8]">Info</span>
            <span class="text-xs text-[var(--monarch-text-muted)] mt-1">Badges</span>
          </div>

          <!-- Avatar preview -->
          <div class="monarch-card p-6 flex flex-col items-center gap-3">
            <div class="flex -space-x-2">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold text-white" style="background: var(--monarch-brand-gradient);">JY</div>
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold bg-[#3B82F6] text-white border-2 border-[var(--monarch-bg-surface)]">EM</div>
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold bg-[#22C55E] text-white border-2 border-[var(--monarch-bg-surface)]">KM</div>
            </div>
            <span class="text-xs text-[var(--monarch-text-muted)] mt-1">Avatars</span>
          </div>

          <!-- Card preview -->
          <div class="monarch-card p-6 flex flex-col items-center gap-3">
            <div class="w-full p-3 rounded-lg bg-[var(--monarch-bg-elevated)] border border-[var(--monarch-border-subtle)]">
              <div class="text-2xl font-bold">433</div>
              <div class="text-xs text-[var(--monarch-text-muted)] uppercase tracking-wider">Accounts</div>
            </div>
            <span class="text-xs text-[var(--monarch-text-muted)] mt-1">Stat Cards</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-[var(--monarch-border-subtle)] px-6 md:px-10 py-8">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-sm text-[var(--monarch-text-muted)]">
          <div class="shrink-0 flex items-center justify-center" style="width: 20px; height: 20px; border-radius: 5px; background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" /><path d="M5 21h14" /></svg>
          </div>
          <span>Monarch Design System</span>
        </div>
        <div class="flex items-center gap-6 text-sm text-[var(--monarch-text-muted)]">
          <a href="https://github.com/emaxon/monarch-design-system" target="_blank" rel="noopener" class="hover:text-[var(--monarch-text-primary)] transition-colors duration-200">GitHub</a>
          <span>Built with Astro + Tailwind</span>
        </div>
      </div>
    </footer>
  </body>
</html>
