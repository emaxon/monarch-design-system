---

<nav class="w-64 shrink-0 h-full overflow-y-auto border-r border-[var(--monarch-border-subtle)]">
  <!-- Logo -->
  <div class="flex items-center gap-2.5 px-5 py-4 border-b border-[var(--monarch-border-subtle)]">
    <MonarchLogo size={28} />
    <span class="text-base font-semibold">Monarch</span>
    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded" style="background-color: rgba(99,102,241,0.15); color: #818cf8;">DS</span>
  </div>

  <div class="py-3 px-3 space-y-4">
    {sections.map((section) => (
      <div>
        <div
          class="nav-section-toggle flex items-center justify-between w-full text-[10px] font-semibold tracking-[0.1em] uppercase mb-2 px-3 cursor-pointer transition-colors duration-200"
          style="border: none; background: none; color: var(--monarch-text-secondary);"
          data-section={section.title}
        >
          {section.title}
          <svg class="nav-chevron w-3 h-3 transition-transform duration-200 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <ul class="nav-section-items space-y-0.5" data-section={section.title}>
          {section.items.map((item) => (
            <li>
              <a
                href={`${base}${item.href}`}
                class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-all duration-200 ${
                  isActive(item.href)
                    ? 'font-medium'
                    : 'text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)]'
                }`}
                style={isActive(item.href) ? 'background-color: rgba(99,102,241,0.1); color: #818cf8; border-left: 2px solid #6366f1;' : ''}
              >
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[item.icon] || icons.book} />
                </svg>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</nav>

<script>
  document.querySelectorAll('.nav-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const items = btn.nextElementSibling;
      const chevron = btn.querySelector('.nav-chevron');
      if (items) items.classList.toggle('hidden');
      if (chevron) chevron.classList.toggle('rotate-180');
    });
  });
</script>
