---
import MonarchLogo from './MonarchLogo.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function isActive(path: string): boolean {
  return currentPath === `${base}${path}` || currentPath === `${base}${path}/`;
}

const sections = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Introduction', href: '/getting-started', icon: 'book' },
    ],
  },
  {
    title: 'Design Tokens',
    items: [
      { label: 'Colors', href: '/tokens/colors', icon: 'palette' },
      { label: 'Typography', href: '/tokens/typography', icon: 'type' },
      { label: 'Spacing', href: '/tokens/spacing', icon: 'grid' },
      { label: 'Shadows', href: '/tokens/shadows', icon: 'layers' },
    ],
  },
  {
    title: 'Atoms',
    items: [
      { label: 'Buttons', href: '/atoms/buttons', icon: 'click' },
      { label: 'Badges', href: '/atoms/badges', icon: 'tag' },
      { label: 'Inputs', href: '/atoms/inputs', icon: 'input' },
      { label: 'Toggles', href: '/atoms/toggles', icon: 'toggle' },
      { label: 'Avatars', href: '/atoms/avatars', icon: 'user' },
    ],
  },
  {
    title: 'Molecules',
    items: [
      { label: 'Cards', href: '/molecules/cards', icon: 'card' },
      { label: 'Stat Cards', href: '/molecules/stat-cards', icon: 'chart' },
      { label: 'Search Bar', href: '/molecules/search-bar', icon: 'search' },
      { label: 'Health Indicators', href: '/molecules/health-indicators', icon: 'heart' },
      { label: 'Nav Items', href: '/molecules/nav-items', icon: 'nav' },
    ],
  },
  {
    title: 'Organisms',
    items: [
      { label: 'Sidebar', href: '/organisms/sidebar', icon: 'sidebar' },
      { label: 'Data Table', href: '/organisms/data-table', icon: 'table' },
      { label: 'Kanban Board', href: '/organisms/kanban-board', icon: 'kanban' },
      { label: 'Agent Feed', href: '/organisms/agent-feed', icon: 'feed' },
      { label: 'Command Palette', href: '/organisms/command-palette', icon: 'command' },
      { label: 'Chat Interface', href: '/organisms/chat-interface', icon: 'chat' },
    ],
