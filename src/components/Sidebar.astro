---
const currentPath = Astro.url.pathname.replace(/\/$/, '');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function isActive(path: string): boolean {
  return currentPath === `${base}${path}` || currentPath === `${base}${path}/`;
}

const sections = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Introduction', href: '/getting-started' },
    ],
  },
  {
    title: 'Design Tokens',
    items: [
      { label: 'Colors', href: '/tokens/colors' },
      { label: 'Typography', href: '/tokens/typography' },
      { label: 'Spacing', href: '/tokens/spacing' },
      { label: 'Shadows', href: '/tokens/shadows' },
    ],
  },
  {
    title: 'Atoms',
    items: [
      { label: 'Buttons', href: '/atoms/buttons' },
      { label: 'Badges', href: '/atoms/badges' },
      { label: 'Inputs', href: '/atoms/inputs' },
      { label: 'Toggles', href: '/atoms/toggles' },
      { label: 'Avatars', href: '/atoms/avatars' },
    ],
  },
  {
    title: 'Molecules',
    items: [
      { label: 'Cards', href: '/molecules/cards' },
      { label: 'Stat Cards', href: '/molecules/stat-cards' },
      { label: 'Search Bar', href: '/molecules/search-bar' },
      { label: 'Health Indicators', href: '/molecules/health-indicators' },
      { label: 'Nav Items', href: '/molecules/nav-items' },
    ],
  },
  {
    title: 'Organisms',
    items: [
      { label: 'Sidebar', href: '/organisms/sidebar' },
      { label: 'Data Table', href: '/organisms/data-table' },
      { label: 'Kanban Board', href: '/organisms/kanban-board' },
      { label: 'Agent Feed', href: '/organisms/agent-feed' },
      { label: 'Command Palette', href: '/organisms/command-palette' },
      { label: 'Chat Interface', href: '/organisms/chat-interface' },
    ],
  },
  {
    title: 'Templates',
    items: [
      { label: 'Dashboard', href: '/templates/dashboard' },
      { label: 'List View', href: '/templates/list-view' },
    ],
  },
];
---

<nav class="w-64 shrink-0 h-full overflow-y-auto px-4 py-6 border-r border-[var(--monarch-border-subtle)]">
  {sections.map((section, si) => (
    <div class={si > 0 ? 'mt-6' : ''}>
      <button
        class="nav-section-toggle flex items-center justify-between w-full text-[10px] font-semibold tracking-[0.1em] uppercase text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] mb-2 px-2 cursor-pointer transition-colors duration-200"
        data-section={section.title}
        style="border: none; background: none; outline: none; -webkit-appearance: none; appearance: none;"
      >
        {section.title}
        <svg class="nav-chevron w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <ul class="nav-section-items space-y-0.5" data-section={section.title}>
        {section.items.map((item) => (
          <li>
            <a
              href={`${base}${item.href}`}
              class={`block px-3 py-1.5 rounded-md text-sm transition-all duration-200 ${
                isActive(item.href)
                  ? 'bg-[rgba(99,102,241,0.12)] text-[var(--monarch-brand-purple)] font-medium border-l-2 border-[var(--monarch-brand-purple)]'
                  : 'text-[var(--monarch-text-secondary)] hover:text-[var(--monarch-text-primary)] hover:bg-[var(--monarch-bg-elevated)]'
              }`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>

<script>
  document.querySelectorAll('.nav-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const section = btn.getAttribute('data-section');
      if (!section) return;
      const items = btn.nextElementSibling;
      const chevron = btn.querySelector('.nav-chevron');
      if (items) {
        items.classList.toggle('hidden');
      }
      if (chevron) {
        chevron.classList.toggle('rotate-180');
      }
    });
  });
</script>
