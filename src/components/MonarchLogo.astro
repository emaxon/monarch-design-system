---
interface Props {
  size?: number;
}

const { size = 32 } = Astro.props;
const iconSize = Math.round(size * 0.5625);
---

<div
  class="shrink-0 flex items-center justify-center"
  style={`width: ${size}px; height: ${size}px; border-radius: ${Math.round(size * 0.25)}px; background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);`}
>
  <svg xmlns="http://www.w3.org/2000/svg" width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z" />
    <path d="M5 21h14" />
  </svg>
</div>
